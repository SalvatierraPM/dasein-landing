---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Dasein Foresight — Prospectiva estratégica basada en IA',
  description = 'Consultora de prospectiva estratégica basada en IA para equipos que necesitan leer señales, modelar sistemas y decidir mejor bajo complejidad.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#f5efe5">
  <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32">
  <link rel="icon" href="/favicon-192.png" type="image/png" sizes="192x192">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">

  <link rel="preconnect" href="https://api.fontshare.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@500,700,900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600&family=Azeret+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

  <title>{title}</title>

  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://dasein.cl/">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://dasein.cl/">
  <meta property="og:image" content="https://dasein.cl/og-image.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="https://dasein.cl/og-image.png">

  <script is:inline>
    const root = document.documentElement;
    root.classList.add('js');
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      root.classList.add('motion-ok');
    }
  </script>
  <noscript>
    <style>
      [data-reveal], [data-reveal-stagger] > * {
        opacity: 1 !important;
        transform: none !important;
        filter: none !important;
      }
      .hero-word, .hero-body, .hero-actions, .hero-kicker {
        opacity: 1 !important;
        transform: none !important;
      }
      .hero-word--strike::after { transform: scaleX(1) !important; }
      .hero-word--strike { color: var(--ink-faint) !important; }
      [data-narrative-p] {
        opacity: 1 !important;
        transform: none !important;
        filter: none !important;
      }
    </style>
  </noscript>
</head>
<body class="grain">
  <div class="cursor-dot" aria-hidden="true"></div>
  <slot />

  <!-- Lenis smooth scroll -->
  <script>
    import Lenis from 'lenis';

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: 'vertical',
        gestureOrientation: 'vertical',
        smoothWheel: true,
        touchMultiplier: 1.5,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      // Expose for anchor links
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          const href = (anchor as HTMLAnchorElement).getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            lenis.scrollTo(target, { offset: -80 });
          }
        });
      });
    }
  </script>

  <script is:inline>
    (() => {
      const dot = document.querySelector('.cursor-dot');
      if (!dot || window.matchMedia('(pointer: coarse)').matches) return;

      let mx = 0, my = 0, dx = 0, dy = 0;
      let running = false;

      document.addEventListener('mousemove', (e) => {
        mx = e.clientX;
        my = e.clientY;
        if (!running) { running = true; tick(); }
      });

      function tick() {
        dx += (mx - dx) * 0.15;
        dy += (my - dy) * 0.15;
        dot.style.transform = 'translate(' + (dx - 4) + 'px,' + (dy - 4) + 'px)';
        if (Math.abs(mx - dx) + Math.abs(my - dy) > 0.1) {
          requestAnimationFrame(tick);
        } else {
          running = false;
        }
      }

      const growTargets = 'a, button, [data-cursor-grow], .audience-lane, .hero-lexicon-word, .engine-card, .marquee-item';
      document.addEventListener('mouseover', (e) => {
        if (e.target.closest(growTargets)) dot.classList.add('is-grow');
      });
      document.addEventListener('mouseout', (e) => {
        if (e.target.closest(growTargets)) dot.classList.remove('is-grow');
      });
    })();
  </script>
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
