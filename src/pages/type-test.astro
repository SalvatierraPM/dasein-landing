</section>

<style>
  /* ═══════════════════════════
     TEST HARNESS STYLES
     ═══════════════════════════ */

  :root {
    --paper: #f5efe5;
    --ink: #111111;
    --ink-soft: #4e4a43;
    --ink-faint: #8f877a;
    --navy: #0a1628;
    --navy-soft: #132238;
    --signal-red: #ff5c38;
    --signal-blue: #4865ff;
    --line: rgba(17, 17, 17, 0.1);
    --slate-white: #ede7dc;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink);
    background: #e8e2d8;
    -webkit-font-smoothing: antialiased;
  }

  .test-header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 1.25rem 2rem;
    background: rgba(17, 17, 17, 0.92);
    backdrop-filter: blur(12px);
    color: var(--slate-white);
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .test-header h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .test-note {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(237, 231, 220, 0.5);
  }

  .toggle-bar {
    margin-left: auto;
    display: flex;
    gap: 0.25rem;
  }

  .toggle-btn {
    appearance: none;
    border: 1px solid rgba(255,255,255,0.15);
    background: transparent;
    color: rgba(255,255,255,0.5);
    padding: 0.4rem 0.8rem;
    border-radius: 4px;
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .toggle-btn.is-active {
    background: rgba(255,255,255,0.12);
    color: white;
    border-color: rgba(255,255,255,0.3);
  }

  .test-section {
    padding: 3rem 2rem 1rem;
  }

  .test-section-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--line);
  }

  .test-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .test-grid.hide-current .test-col--current { display: none; }
  .test-grid.hide-proposed .test-col--proposed { display: none; }
  .test-grid.hide-current,
  .test-grid.hide-proposed {
    grid-template-columns: 1fr;
  }

  .col-label {
    display: block;
    font-family: 'Space Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 0.75rem;
  }

  .demo-paper {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: clamp(2rem, 3vw, 3rem);
  }

  .demo-dark {
    background: var(--navy);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: clamp(2rem, 3vw, 3rem);
    color: var(--slate-white);
  }

  /* ═══════════════════════════
     CURRENT SYSTEM STYLES
     ═══════════════════════════ */

  /* — Kickers & labels — */
  .cur-kicker {
    font-family: 'Azeret Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .cur-kicker::before {
    content: '';
    width: 1.4rem;
    height: 1px;
    background: currentColor;
    opacity: 0.55;
  }

  /* — Hero title — */
  .cur-hero-title {
    font-family: 'Satoshi', sans-serif;
    font-size: clamp(2.8rem, 2rem + 3vw, 5rem);
    font-weight: 600;
    line-height: 0.95;
    letter-spacing: -0.05em;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
    margin-bottom: 1.5rem;
  }

  .cur-editorial {
    font-family: 'Instrument Serif', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    color: var(--signal-red);
  }

  .cur-mono-small {
    font-family: 'Azeret Mono', monospace;
    font-size: 0.55em;
    letter-spacing: 0.04em;
    font-weight: 400;
    color: var(--ink-faint);
  }

  .cur-strike {
    position: relative;
    color: var(--ink-faint);
  }

  .cur-strike::after {
    content: '';
    position: absolute;
    left: -4%; right: -4%; top: 52%;
    height: 3px;
    background: var(--signal-red);
  }

  /* — Body — */
  .cur-body {
    font-family: 'Satoshi', sans-serif;
    font-size: clamp(1rem, 0.95rem + 0.28vw, 1.16rem);
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 36rem;
    margin-bottom: 1.5rem;
  }

  /* — Buttons — */
  .cur-buttons { display: flex; gap: 0.875rem; flex-wrap: wrap; }

  .cur-btn-primary {
