---
/**
 * Typographic comparison: CURRENT vs PROPOSED system
 * Current: Satoshi (display/body) + Azeret Mono + Instrument Serif (editorial accent)
 * Proposed: Instrument Serif (display) + Space Grotesk (body) + Space Mono + Newsreader (editorial prose)
 */
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Type Test — Dasein Foresight</title>

  <!-- Current fonts -->
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,600,700&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Azeret+Mono:wght@400;500;600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

  <!-- Proposed fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,300;1,6..72,400;1,6..72,500&display=swap" rel="stylesheet">
</head>
<body>

<header class="test-header">
  <h1>Evolución tipográfica — A / B</h1>
  <p class="test-note">Izquierda = sistema actual &nbsp;/&nbsp; Derecha = propuesta editorial</p>
  <div class="toggle-bar">
    <button class="toggle-btn is-active" data-view="split">Split</button>
    <button class="toggle-btn" data-view="current">Solo actual</button>
    <button class="toggle-btn" data-view="proposed">Solo propuesta</button>
  </div>
</header>

<!-- ═══════════════════════════════════════════
     SECTION 1: HERO
     ═══════════════════════════════════════════ -->

<section class="test-section">
  <h2 class="test-section-label">01 — Hero</h2>
  <div class="test-grid" data-grid>

    <!-- CURRENT -->
    <div class="test-col test-col--current" data-col="current">
      <span class="col-label">ACTUAL</span>
      <div class="hero-demo demo-paper">
        <p class="cur-kicker">Prospectiva estratégica basada en IA</p>
        <div class="cur-hero-title">
          <span>Decidir</span>
          <span><em class="cur-editorial">antes</em> <span class="cur-mono-small">de</span></span>
          <span class="cur-strike">reaccionar.</span>
        </div>
        <p class="cur-body">
          Consultora de prospectiva estratégica. Exploramos futuros plausibles
          para que tu organización decida antes de que la realidad lo haga por ella.
        </p>
        <div class="cur-buttons">
          <span class="cur-btn-primary">Agenda una conversación</span>
          <span class="cur-btn-secondary">Ver el método</span>
        </div>
      </div>
    </div>

    <!-- PROPOSED -->
    <div class="test-col test-col--proposed" data-col="proposed">
      <span class="col-label">PROPUESTA</span>
      <div class="hero-demo demo-paper">
        <p class="pro-kicker">Prospectiva estratégica basada en IA</p>
        <div class="pro-hero-title">
          <span>Decidir</span>
          <span><em class="pro-newsreader-accent">antes</em> <span class="pro-mono-small">de</span></span>
          <span class="pro-strike">reaccionar.</span>
        </div>
        <p class="pro-body">
          Consultora de prospectiva estratégica. Exploramos futuros plausibles
          para que tu organización decida antes de que la realidad lo haga por ella.
        </p>
        <div class="pro-buttons">
          <span class="pro-btn-primary">Agenda una conversación</span>
          <span class="pro-btn-secondary">Ver el método</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 2: DISCLOSURE (Dark)
     ═══════════════════════════════════════════ -->

<section class="test-section">
  <h2 class="test-section-label">02 — Hero Disclosure (dark)</h2>
  <div class="test-grid" data-grid>

    <div class="test-col test-col--current" data-col="current">
      <span class="col-label">ACTUAL</span>
      <div class="disclosure-demo demo-dark">
        <span class="cur-tag">Signal surface</span>
        <h3 class="cur-disclosure-title">Leemos</h3>
        <span class="cur-disclosure-word">señales.</span>
        <p class="cur-disclosure-note">Señales, actores, fricciones y escenarios que luego pasan por simulación.</p>
      </div>
    </div>

    <div class="test-col test-col--proposed" data-col="proposed">
      <span class="col-label">PROPUESTA</span>
      <div class="disclosure-demo demo-dark">
        <span class="pro-tag">Signal surface</span>
        <h3 class="pro-disclosure-title">Leemos</h3>
        <span class="pro-disclosure-word">señales.</span>
        <p class="pro-disclosure-note">Señales, actores, fricciones y escenarios que luego pasan por simulación.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 3: AUDIENCE LANES
     ═══════════════════════════════════════════ -->

<section class="test-section">
  <h2 class="test-section-label">03 — Audience Lanes</h2>
  <div class="test-grid" data-grid>

    <div class="test-col test-col--current" data-col="current">
      <span class="col-label">ACTUAL</span>
      <div class="audience-demo demo-paper">
        <span class="cur-kicker">01 / Para quién</span>
        <h3 class="cur-audience-headline">
          Estamos construyendo.<br />
          <em class="cur-editorial">Buscamos a quienes faltan.</em>
        </h3>
        <p class="cur-lead">Cuatro formas de trabajar con nosotros, según dónde estés y qué necesites.</p>
        <div class="lane-demo">
          <div class="lane-left">
            <span class="cur-num">01</span>
            <span class="cur-label-mono">Pilotos</span>
          </div>
          <h4 class="cur-lane-title">Organizaciones que quieran probar el enfoque con un caso real.</h4>
        </div>
        <div class="lane-demo">
          <div class="lane-left">
            <span class="cur-num">02</span>
            <span class="cur-label-mono">Partners</span>
          </div>
          <h4 class="cur-lane-title">Firmas que implementan mejor cuando el mapa ya existe.</h4>
        </div>
      </div>
    </div>

    <div class="test-col test-col--proposed" data-col="proposed">
      <span class="col-label">PROPUESTA</span>
      <div class="audience-demo demo-paper">
        <span class="pro-kicker">01 / Para quién</span>
        <h3 class="pro-audience-headline">
          Estamos construyendo.<br />
          <em class="pro-newsreader-accent">Buscamos a quienes faltan.</em>
        </h3>
        <p class="pro-lead">Cuatro formas de trabajar con nosotros, según dónde estés y qué necesites.</p>
        <div class="lane-demo">
          <div class="lane-left">
            <span class="pro-num">01</span>
            <span class="pro-label-mono">Pilotos</span>
          </div>
          <h4 class="pro-lane-title">Organizaciones que quieran probar el enfoque con un caso real.</h4>
        </div>
        <div class="lane-demo">
          <div class="lane-left">
            <span class="pro-num">02</span>
            <span class="pro-label-mono">Partners</span>
          </div>
          <h4 class="pro-lane-title">Firmas que implementan mejor cuando el mapa ya existe.</h4>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 4: METHOD / TIMELINE
     ═══════════════════════════════════════════ -->

<section class="test-section">
  <h2 class="test-section-label">04 — Método (Timeline)</h2>
  <div class="test-grid" data-grid>

    <div class="test-col test-col--current" data-col="current">
      <span class="col-label">ACTUAL</span>
      <div class="method-demo demo-paper">
        <span class="cur-kicker">02 / Método</span>
        <h3 class="cur-method-headline">
          Seis pasos para<br />convertir complejidad<br />
          <em class="cur-editorial">en decisión.</em>
        </h3>
        <p class="cur-lead">De la pregunta estratégica al plan a 90 días.</p>
        <div class="step-demo">
          <span class="cur-step-num">01</span>
          <h4 class="cur-step-title">Exploración general</h4>
          <p class="cur-step-body">Delimitamos la pregunta estratégica, el contexto y los frentes donde una mala lectura puede disparar costos innecesarios.</p>
          <div class="cur-step-output">
            <span class="cur-output-label">Output</span>
            <span class="cur-output-value">Pregunta afinada y entorno legible</span>
          </div>
        </div>
        <p class="cur-terminal">El método no se presenta como misterio. Se despliega como sistema visible.▌</p>
      </div>
    </div>

    <div class="test-col test-col--proposed" data-col="proposed">
      <span class="col-label">PROPUESTA</span>
      <div class="method-demo demo-paper">
        <span class="pro-kicker">02 / Método</span>
        <h3 class="pro-method-headline">
          Seis pasos para<br />convertir complejidad<br />
          <em class="pro-newsreader-accent">en decisión.</em>
        </h3>
        <p class="pro-lead">De la pregunta estratégica al plan a 90 días.</p>
        <div class="step-demo">
          <span class="pro-step-num">01</span>
          <h4 class="pro-step-title">Exploración general</h4>
          <p class="pro-step-body">Delimitamos la pregunta estratégica, el contexto y los frentes donde una mala lectura puede disparar costos innecesarios.</p>
          <div class="pro-step-output">
            <span class="pro-output-label">Output</span>
            <span class="pro-output-value">Pregunta afinada y entorno legible</span>
          </div>
        </div>
        <p class="pro-terminal">El método no se presenta como misterio. Se despliega como sistema visible.▌</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
     SECTION 5: FOUNDER
     ═══════════════════════════════════════════ -->

<section class="test-section">
  <h2 class="test-section-label">05 — Founder</h2>
  <div class="test-grid" data-grid>

    <div class="test-col test-col--current" data-col="current">
      <span class="col-label">ACTUAL</span>
      <div class="founder-demo demo-paper">
        <span class="cur-kicker">03 / Origen</span>
        <h3 class="cur-founder-title">Dasein nace de implementar IA donde el error tiene costo real.</h3>
        <div class="founder-narrative-demo">
          <p class="cur-narrative-p cur-narrative-first">
            Soy Pablo Moraga. Vengo de implementar agentes de IA en entornos reales,
            donde los errores no son teóricos y las decisiones cambian operaciones.
          </p>
          <p class="cur-narrative-p">
            Dasein Foresight nace desde ahí. No como un ejercicio académico de futuros
            posibles, sino como una herramienta para tomar mejores decisiones hoy.
          </p>
        </div>
        <div class="byline-demo">
          <span class="cur-byline-name">Pablo Moraga</span>
          <span class="cur-byline-sep">/</span>
          <span class="cur-byline-role">Founder, Dasein Foresight</span>
        </div>
      </div>
    </div>

    <div class="test-col test-col--proposed" data-col="proposed">
      <span class="col-label">PROPUESTA</span>
      <div class="founder-demo demo-paper">
        <span class="pro-kicker">03 / Origen</span>
        <h3 class="pro-founder-title">Dasein nace de implementar IA donde el error tiene costo real.</h3>
        <div class="founder-narrative-demo pro-narrative-border">
          <p class="pro-narrative-p pro-narrative-first">
            Soy Pablo Moraga. Vengo de implementar agentes de IA en entornos reales,
            donde los errores no son teóricos y las decisiones cambian operaciones.
          </p>
          <p class="pro-narrative-p">
            Dasein Foresight nace desde ahí. No como un ejercicio académico de futuros
            posibles, sino como una herramienta para tomar mejores decisiones hoy.
          </p>
        </div>
        <div class="byline-demo">
          <span class="pro-byline-name">Pablo Moraga</span>
          <span class="pro-byline-sep">/</span>
          <span class="pro-byline-role">Founder, Dasein Foresight</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════
