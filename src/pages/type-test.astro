  .pro-scale-body { font-family: 'Space Grotesk', sans-serif; font-size: 1.05rem; line-height: 1.7; color: var(--ink-soft); }
  .pro-scale-newsreader { font-family: 'Newsreader', Georgia, serif; font-size: 1.1rem; font-style: normal; font-weight: 400; line-height: 1.75; color: var(--ink-soft); }
  .pro-scale-mono { font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 0.18em; color: var(--ink-faint); }
  .pro-scale-caption { font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em; color: var(--ink-faint); }

  /* ═══════════════════════════
     RESPONSIVE
     ═══════════════════════════ */

  @media (max-width: 900px) {
    .test-grid { grid-template-columns: 1fr; }
    .test-header { flex-wrap: wrap; }
    .toggle-bar { margin-left: 0; }
  }
</style>

<script>
  const buttons = document.querySelectorAll('.toggle-btn');
  const grids = document.querySelectorAll('[data-grid]');

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');

      const view = btn.getAttribute('data-view');

      grids.forEach((grid) => {
        grid.classList.remove('hide-current', 'hide-proposed');
        if (view === 'current') grid.classList.add('hide-proposed');
        if (view === 'proposed') grid.classList.add('hide-current');
      });
    });
  });
</script>

</body>
</html>
