<!-- ═══════════════════════════════════════════
     SECTION 7: TYPOGRAPHY SCALE
     ═══════════════════════════════════════════ -->

<section class="test-section">
  <h2 class="test-section-label">07 — Escala tipográfica completa</h2>
  <div class="test-grid" data-grid>

    <div class="test-col test-col--current" data-col="current">
      <span class="col-label">ACTUAL</span>
      <div class="scale-demo demo-paper">
        <div class="scale-row"><span class="scale-label">Display</span><span class="cur-scale-display">Dasein</span></div>
        <div class="scale-row"><span class="scale-label">H1</span><span class="cur-scale-h1">Prospectiva estratégica</span></div>
        <div class="scale-row"><span class="scale-label">H2</span><span class="cur-scale-h2">Seis pasos para decidir</span></div>
        <div class="scale-row"><span class="scale-label">H3</span><span class="cur-scale-h3">Exploración general</span></div>
        <div class="scale-row"><span class="scale-label">Body</span><span class="cur-scale-body">Consultora de prospectiva estratégica basada en IA para equipos que necesitan leer señales.</span></div>
        <div class="scale-row"><span class="scale-label">Editorial</span><span class="cur-scale-editorial">antes de reaccionar</span></div>
        <div class="scale-row"><span class="scale-label">Mono</span><span class="cur-scale-mono">SIGNAL SURFACE · 01 / MÉTODO</span></div>
        <div class="scale-row"><span class="scale-label">Caption</span><span class="cur-scale-caption">30 MIN · REMOTA · ZOHO BOOKINGS</span></div>
      </div>
    </div>

    <div class="test-col test-col--proposed" data-col="proposed">
      <span class="col-label">PROPUESTA</span>
      <div class="scale-demo demo-paper">
        <div class="scale-row"><span class="scale-label">Display</span><span class="pro-scale-display">Dasein</span></div>
        <div class="scale-row"><span class="scale-label">H1</span><span class="pro-scale-h1">Prospectiva estratégica</span></div>
        <div class="scale-row"><span class="scale-label">H2</span><span class="pro-scale-h2">Seis pasos para decidir</span></div>
        <div class="scale-row"><span class="scale-label">H3</span><span class="pro-scale-h3">Exploración general</span></div>
        <div class="scale-row"><span class="scale-label">Body</span><span class="pro-scale-body">Consultora de prospectiva estratégica basada en IA para equipos que necesitan leer señales.</span></div>
        <div class="scale-row"><span class="scale-label">Newsreader</span><span class="pro-scale-newsreader">Dasein Foresight nace desde ahí. No como un ejercicio académico de futuros posibles, sino como una herramienta para tomar mejores decisiones hoy cuando la complejidad ya afecta.</span></div>
        <div class="scale-row"><span class="scale-label">Mono</span><span class="pro-scale-mono">SIGNAL SURFACE · 01 / MÉTODO</span></div>
        <div class="scale-row"><span class="scale-label">Caption</span><span class="pro-scale-caption">30 MIN · REMOTA · ZOHO BOOKINGS</span></div>
      </div>
