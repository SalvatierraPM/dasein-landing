---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AudienceLanes from '../components/AudienceLanes.astro';
import Timeline from '../components/Timeline.astro';
import FounderSection from '../components/FounderSection.astro';
import DeliverablesSection from '../components/DeliverablesSection.astro';
import AllianceSection from '../components/AllianceSection.astro';
import SignalTicker from '../components/SignalTicker.astro';
import JoinSection from '../components/JoinSection.astro';
import Contact from '../components/Contact.astro';
import DecorativeAccents from '../components/DecorativeAccents.astro';
import MouseParticles from '../components/MouseParticles.astro';
import MagneticCTA from '../components/MagneticCTA.astro';
import CTAEyes from '../components/CTAEyes.astro';
import BrandLogo from '../components/BrandLogo.astro';
---

<Layout
  title="Dasein Foresight — Prospectiva estratégica basada en IA"
  description="Dasein Foresight es una consultora de prospectiva estratégica basada en IA que combina señales, simulación y lectura de sistemas complejos para ayudar a organizaciones a decidir mejor bajo incertidumbre."
>
  <nav class="site-nav" id="site-nav" aria-label="Navegación principal">
    <div class="container nav-wrap">
      <a href="#hero" class="brand-lockup">
        <BrandLogo
          size="nav"
          caption="Prospectiva estratégica basada en IA"
        />
      </a>

      <button class="nav-burger" id="nav-burger" aria-label="Abrir menú" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>

      <div class="nav-links" id="nav-links">
        <a href="#servicios">Servicios</a>
        <a href="#metodo">Método</a>
        <a href="#sobre">Origen</a>
        <a href="#contacto" class="nav-cta">Agenda</a>
      </div>
    </div>
  </nav>

  <MouseParticles />
  <main class="page-shell" id="main-content">
    <DecorativeAccents />
    <Hero />
    <DeliverablesSection />
    <Timeline />
    <SignalTicker />
    <FounderSection />
    <AudienceLanes />
    <AllianceSection />
    <JoinSection />
    <Contact />
    <MagneticCTA />
    <CTAEyes />
  </main>

  <script>
    const nav = document.getElementById('site-nav');
    let lastY = window.scrollY;

    const syncNav = () => {
      const currentY = window.scrollY;
      nav?.classList.toggle('is-scrolled', currentY > 12);
      nav?.classList.toggle('is-hidden', currentY > lastY && currentY > 260);
      lastY = currentY;
    };

    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      });
    }, { threshold: 0.18, rootMargin: '0px 0px -12% 0px' });

    document.querySelectorAll('[data-reveal], [data-reveal-stagger], [data-line-reveal], [data-scale-in]').forEach((element) => {
      revealObserver.observe(element);
    });

    syncNav();
    window.addEventListener('scroll', syncNav, { passive: true });

    // Mobile burger menu
    const burger = document.getElementById('nav-burger');
    const navLinks = document.getElementById('nav-links');
    if (burger && navLinks) {
      burger.addEventListener('click', () => {
        const open = navLinks.classList.toggle('is-open');
        burger.classList.toggle('is-open', open);
        burger.setAttribute('aria-expanded', String(open));
      });
      navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          navLinks.classList.remove('is-open');
          burger.classList.remove('is-open');
          burger.setAttribute('aria-expanded', 'false');
        });
      });
    }

    document.addEventListener('astro:before-preparation', () => {
      revealObserver.disconnect();
      window.removeEventListener('scroll', syncNav);
    }, { once: true });

    /* ── Scroll-driven parallax for 3D objects ── */
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const items = document.querySelectorAll<HTMLElement>('[data-parallax]');
      if (!items.length) return;
      let ticking = false;
      const update = () => {
        const y = window.scrollY;
        items.forEach((el) => {
          const speed = parseFloat(el.dataset.parallax || '0');
          el.style.setProperty('--plx-y', `${-(y * speed)}px`);
        });
      };
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => { update(); ticking = false; });
          ticking = true;
        }
      }, { passive: true });
      update();
    })();

    /* ── Section color transitions ── */
    /* Sections with class .section-dark get a smooth crossfade overlay
       that activates as they enter the viewport. Avoids hard cuts. */
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const darkSections = document.querySelectorAll<HTMLElement>('.section-dark, .hero-disclosure-shell');
      if (!darkSections.length) return;

      let ticking = false;
      const update = () => {
        const vh = window.innerHeight;
        darkSections.forEach((section) => {
          const rect = section.getBoundingClientRect();
          // How much of the section is in view (0 to 1)
          const visible = Math.max(0, Math.min(1,
            (vh - rect.top) / (vh * 0.3)
          ));
          section.style.setProperty('--section-presence', String(visible));
        });
      };

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => { update(); ticking = false; });
          ticking = true;
        }
      }, { passive: true });
      update();
    })();

    /* ── Text scramble on section kickers ── */
    /* When a kicker enters viewport, its text briefly scrambles then resolves.
       Terminal/hacker aesthetic that fits the mono font. */
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789/·—';
      const kickers = document.querySelectorAll<HTMLElement>('.section-kicker, .section-index');

      const scramble = (el: HTMLElement) => {
        const original = el.textContent || '';
        const len = original.length;
        let frame = 0;
        const totalFrames = 18;

        const tick = () => {
          let result = '';
          for (let i = 0; i < len; i++) {
            if (original[i] === ' ' || original[i] === '/') {
              result += original[i];
            } else if (frame > totalFrames * (i / len) + 4) {
              result += original[i]; // resolved
            } else {
              result += chars[Math.floor(Math.random() * chars.length)];
            }
          }
          el.textContent = result;
          frame++;
          if (frame < totalFrames + 8) {
            requestAnimationFrame(tick);
          } else {
            el.textContent = original;
          }
        };
        requestAnimationFrame(tick);
      };

      const kickerObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          scramble(entry.target as HTMLElement);
          kickerObserver.unobserve(entry.target);
        });
      }, { threshold: 0.5 });

      kickers.forEach((k) => kickerObserver.observe(k));
    })();

    /* Marquees run at fixed CSS speed — no scroll reactivity */
  </script>
</Layout>

<style>
  .page-shell {
    position: relative;
  }

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(18px);
    background: rgba(248, 244, 237, 0.82);
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
    transition: transform var(--dur-normal) var(--ease-out-expo), background-color var(--dur-normal) ease;
  }

  .site-nav.is-scrolled {
    background: rgba(248, 244, 237, 0.92);
  }

  .site-nav.is-hidden {
    transform: translateY(-100%);
  }

  .nav-wrap {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .brand-lockup {
    display: block;
    min-width: 10rem;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.1rem;
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .nav-links a:hover {
    color: var(--ink);
  }

  .nav-links .nav-cta {
    padding: 0.75rem 1rem;
    border-radius: var(--radius-full);
    background: rgba(17, 17, 17, 0.06);
    color: var(--ink);
  }

  .nav-links .nav-cta:hover {
    background: rgba(17, 17, 17, 0.12);
  }

  /* Burger button — hidden on desktop */
  .nav-burger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    flex-direction: column;
    gap: 4px;
    z-index: 10;
  }

  .nav-burger span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--ink);
    transition: transform 0.25s ease, opacity 0.2s ease;
    transform-origin: center;
  }

  .nav-burger.is-open span:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  .nav-burger.is-open span:nth-child(2) {
    opacity: 0;
  }
  .nav-burger.is-open span:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }

  @media (max-width: 840px) {
    .nav-wrap {
      flex-wrap: nowrap;
    }

    .brand-lockup {
      min-width: 0;
      flex: 1;
    }

    .nav-burger {
      display: flex;
    }

    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      background: rgba(248, 244, 237, 0.97);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(17, 17, 17, 0.08);
      padding: 1rem var(--gutter);
      gap: 0;
      transform: translateY(-10px);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.25s var(--ease-out-expo), opacity 0.2s ease;
    }

    .nav-links.is-open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .nav-links a {
      padding: 0.75rem 0;
      border-bottom: 1px solid rgba(17, 17, 17, 0.06);
      font-size: 0.8rem;
    }

    .nav-links a:last-child {
      border-bottom: none;
    }

    .nav-links .nav-cta {
      margin-top: 0.5rem;
      text-align: center;
      border-radius: var(--radius-full);
    }
  }
</style>
