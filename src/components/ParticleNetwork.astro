---
interface Props {
  /** CSS class to add to the wrapper */
  class?: string;
  /** Base color for particles in hex */
  color?: string;
  /** Number of particles (auto-reduced on mobile) */
  count?: number;
  /** Overall opacity of the canvas, 0-1 */
  opacity?: number;
  /** Maximum connection distance in px */
  linkDistance?: number;
}

const {
  class: className = '',
  color = '#4865ff',
  count = 60,
  opacity = 0.32,
  linkDistance = 120,
} = Astro.props;
---

<div
  class={`particle-network ${className}`}
  data-particle-network
  data-pn-color={color}
  data-pn-count={String(count)}
  data-pn-opacity={String(opacity)}
  data-pn-link-distance={String(linkDistance)}
  aria-hidden="true"
>
  <canvas class="particle-network__canvas"></canvas>
</div>

<style>
  .particle-network {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .particle-network__canvas {
    width: 100%;
    height: 100%;
  }
</style>

<script>
  function initAllParticleNetworks() {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const allNets = document.querySelectorAll('[data-particle-network]');

    allNets.forEach((root) => {
      if (
        !(root instanceof HTMLElement) ||
        root.dataset.pnMounted === 'true' ||
        reducedMotion
      ) return;

      root.dataset.pnMounted = 'true';

      const observer = new IntersectionObserver((entries) => {
        if (!entries.some((e) => e.isIntersecting)) return;
        observer.disconnect();
        const canvas = root.querySelector('canvas');
        if (canvas) initNetwork(root, canvas as HTMLCanvasElement);
      }, { rootMargin: '200px 0px' });

      observer.observe(root);
    });
  }

  interface Particle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    baseVx: number;
    baseVy: number;
    r: number;
    baseR: number;
    baseAlpha: number;
    /** Angle for orbital scroll-driven motion */
    angle: number;
    /** Distance from center for scroll orbit */
    orbitRadius: number;
    /** Home position (center-relative) for scroll-driven displacement */
    homeX: number;
    homeY: number;
  }

  function initNetwork(root: HTMLElement, canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const colorHex = root.dataset.pnColor || '#4865ff';
    const isMobile = window.innerWidth < 768;
    const baseCount = parseInt(root.dataset.pnCount || '60', 10);
    const particleCount = isMobile ? Math.floor(baseCount * 0.5) : baseCount;
    const globalOpacity = parseFloat(root.dataset.pnOpacity || '0.32');
    const linkDist = parseInt(root.dataset.pnLinkDistance || '120', 10);

    // Parse hex to rgb
    const r = parseInt(colorHex.slice(1, 3), 16);
    const g = parseInt(colorHex.slice(3, 5), 16);
    const b = parseInt(colorHex.slice(5, 7), 16);

    let w = 0;
    let h = 0;
    let disposed = false;
    let rafId = 0;
    const dpr = Math.min(window.devicePixelRatio, 2);

    const particles: Particle[] = [];

    // Scroll-driven state
    let scrollProgress = 0; // 0-1 across all steps
    let currentStep = 0;
    const totalSteps = 6;

    const resize = () => {
      w = root.clientWidth;
      h = root.clientHeight;
      if (!w || !h) return;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(root);
    resize();

    // Seed particles
    for (let i = 0; i < particleCount; i++) {
      const px = Math.random() * (w || 800);
      const py = Math.random() * (h || 600);
      const bvx = (Math.random() - 0.5) * 0.3;
      const bvy = (Math.random() - 0.5) * 0.3;
      particles.push({
        x: px,
        y: py,
        vx: bvx,
        vy: bvy,
        baseVx: bvx,
        baseVy: bvy,
        r: 1.5 + Math.random() * 2,
        baseR: 1.5 + Math.random() * 2,
        baseAlpha: 0.4 + Math.random() * 0.6,
        angle: Math.random() * Math.PI * 2,
        orbitRadius: 30 + Math.random() * 80,
        homeX: px,
        homeY: py,
      });
    }

    // Watch the method root for step changes
    const methodRoot = root.closest('[data-method-root]') || document.querySelector('[data-method-root]');

    if (methodRoot) {
      const stepObserver = new MutationObserver(() => {
        const step = parseInt(methodRoot.getAttribute('data-active-step') || '0', 10);
        currentStep = step;
        scrollProgress = step / (totalSteps - 1);
      });
      stepObserver.observe(methodRoot, { attributes: true, attributeFilter: ['data-active-step'] });

      // Also track continuous scroll progress within the scrolly container
      const scrollyContainer = methodRoot as HTMLElement;
      const updateScrollProgress = () => {
        if (disposed) return;
        const rect = scrollyContainer.getBoundingClientRect();
        const viewH = window.innerHeight;
        const totalScroll = rect.height - viewH;
        if (totalScroll <= 0) return;
        const scrolled = -rect.top;
        scrollProgress = Math.max(0, Math.min(1, scrolled / totalScroll));
        currentStep = Math.min(totalSteps - 1, Math.floor(scrollProgress * totalSteps));
      };

      window.addEventListener('scroll', updateScrollProgress, { passive: true });
    }

    // Visibility tracking to pause when off-screen
    let isVisible = true;
    const visObs = new IntersectionObserver((entries) => {
      isVisible = entries.some((e) => e.isIntersecting);
    }, { threshold: 0 });
    visObs.observe(root);

    const animate = () => {
      if (disposed) return;
      rafId = requestAnimationFrame(animate);
      if (!isVisible || !w || !h) return;

      ctx.clearRect(0, 0, w, h);

      const cx = w / 2;
      const cy = h / 2;

      // Scroll-driven modifiers:
      // - spread: particles expand outward as you scroll deeper
      // - speed: particles move faster at later steps
      // - size: particles grow slightly with progress
      const spread = 0.3 + scrollProgress * 1.4;     // 0.3 → 1.7
      const speedMul = 0.6 + scrollProgress * 1.8;   // 0.6 → 2.4
      const sizeMul = 1 + scrollProgress * 0.6;       // 1 → 1.6
      const alphaMul = 0.7 + scrollProgress * 0.5;   // 0.7 → 1.2
      const activeLinkDist = linkDist * (0.8 + scrollProgress * 0.6); // grow connections

      // Move particles — base velocity + scroll-driven orbital push
      for (const p of particles) {
        // Orbital displacement tied to scroll
        p.angle += 0.003 * speedMul;
        const orbitX = Math.cos(p.angle) * p.orbitRadius * spread * 0.15;
        const orbitY = Math.sin(p.angle) * p.orbitRadius * spread * 0.15;

        // Push particles outward from center as scroll progresses
        const dx = p.x - cx;
        const dy = p.y - cy;
        const dist = Math.sqrt(dx * dx + dy * dy) || 1;
        const pushStrength = scrollProgress * 0.08;
        const pushX = (dx / dist) * pushStrength;
        const pushY = (dy / dist) * pushStrength;

        p.vx = p.baseVx * speedMul + orbitX * 0.02 + pushX;
        p.vy = p.baseVy * speedMul + orbitY * 0.02 + pushY;

        p.x += p.vx;
        p.y += p.vy;

        // Dynamic radius tied to scroll
        p.r = p.baseR * sizeMul;

        if (p.x < -10) p.x = w + 10;
        if (p.x > w + 10) p.x = -10;
        if (p.y < -10) p.y = h + 10;
        if (p.y > h + 10) p.y = -10;
      }

      // Draw links
      const activeLinkDistSq = activeLinkDist * activeLinkDist;
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const distSq = dx * dx + dy * dy;

          if (distSq < activeLinkDistSq) {
            const alpha = (1 - distSq / activeLinkDistSq) * globalOpacity * 0.5 * alphaMul;
            ctx.strokeStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
            ctx.lineWidth = 0.5 + scrollProgress * 0.5;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.stroke();
          }
        }
      }

      // Draw particles
      for (const p of particles) {
        const alpha = Math.min(1, p.baseAlpha * globalOpacity * alphaMul);
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      }
    };

    animate();

    const cleanup = () => {
      disposed = true;
      cancelAnimationFrame(rafId);
      resizeObserver.disconnect();
      visObs.disconnect();
    };

    document.addEventListener('astro:before-preparation', cleanup, { once: true });
  }

  initAllParticleNetworks();
</script>
