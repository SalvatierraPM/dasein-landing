---
import TextSplitter from './TextSplitter.astro';

const tiers = [
  {
    num: '00',
    name: 'Pulso Rápido',
    tag: 'Quick read',
    price: '$1,500',
    priceNum: 1500,
    time: '2–3 días',
    level: 'puntual',
    levelColor: 'var(--foresight-teal)',
    headline: 'Una pregunta, <em>una respuesta.</em>',
    benefit: 'Obtén claridad sobre lo que se está moviendo en tu entorno en 3 días.',
    body: 'Qué se está moviendo, qué señales hay, qué preguntas deberías estar haciéndote. Respuesta rápida a 1 decisión concreta.',
    includes: ['Memo ejecutivo', 'Señales clave', '3 preguntas críticas'],
  },
  {
    num: '01',
    name: 'Lectura de Campo',
    tag: 'Full scan',
    price: '$5,000',
    priceNum: 5000,
    time: '5–7 días',
    level: 'puntual',
    levelColor: 'var(--foresight-teal)',
    headline: 'El mapa completo de tu entorno <em>antes de actuar.</em>',
    benefit: 'Identifica quién importa, qué fuerzas se mueven y dónde están los riesgos antes de que te afecten.',
    body: 'Quién importa, qué fuerzas se mueven, dónde están los riesgos, y qué hacer en los próximos 90 días.',
    includes: ['Radar visual del entorno', 'Mapa de actores (15–25)', 'Signposts', 'Plan a 90 días'],
  },
  {
    num: '02',
    name: 'Simulación Táctica',
    tag: 'First sim',
    price: '$12,000',
    priceNum: 12000,
    time: '2–3 semanas',
    level: 'estrategico',
    levelColor: 'var(--signal-blue)',
    headline: 'Ensaya una decisión <em>antes de tomarla.</em>',
    benefit: 'Ve cómo reaccionaría tu ecosistema ante una decisión concreta antes de comprometerte.',
    body: 'Simulamos cómo reaccionan los actores y te mostramos 3 futuros posibles en un dashboard interactivo.',
    includes: ['1 decisión simulada', '3 escenarios', 'Dashboard interactivo', 'Reporte ejecutivo'],
  },
  {
    num: '03',
    name: 'Simulación Estratégica',
    tag: 'Full ecosystem',
    price: '$28,000',
    priceNum: 28000,
    time: '5–6 semanas',
    level: 'estrategico',
    levelColor: 'var(--signal-blue)',
    featured: true,
    headline: 'Todo tu ecosistema, <em>simulado.</em>',
    benefit: 'Tu directorio toma decisiones con escenarios simulados, no con intuición.',
    body: 'Todos los actores, todas las dinámicas. Con taller presencial donde tu directorio convierte resultados en decisiones.',
    includes: ['Ecosistema completo', '12–60 actores', 'Dashboard + dossier', 'Workshop presencial', 'Matriz de acción'],
  },
  {
    num: '04',
    name: 'Radar Estratégico',
    tag: 'Ongoing',
    price: '$6,000/mes',
    priceNum: 6000,
    time: 'Continuo · min 6 meses',
    level: 'continuo',
    levelColor: 'var(--horizon-violet)',
    headline: 'Vigilancia permanente. <em>Siempre adelante.</em>',
    benefit: 'Tu equipo nunca más decide con información de hace 6 meses.',
    body: 'Cada mes detectamos qué cambió, cada trimestre re-simulamos. Tu equipo nunca más decide con información vieja.',
    includes: ['Scan mensual de señales', 'Re-simulación trimestral', 'Sesión trimestral', 'Acceso prioritario'],
  },
];

const bookingUrl = 'https://daseinforesight.zohobookings.com/#/4731633000000049054';
---

<section class="services-section" id="servicios">
  <div class="services-container">

    <!-- Section header -->
    <header class="services-header" data-reveal>
      <div class="services-header__kicker">
        <span class="section-index">01 / Servicios</span>
      </div>
      <div class="services-header__title" data-line-reveal>
        <h2>Cinco formatos. Desde una pregunta rápida hasta <em>monitoreo continuo.</em></h2>
        <div class="services-header__copy">
          <TextSplitter
            text="No vendemos horas de consultoría. Vendemos entregables que un directorio puede usar para decidir."
            tag="p"
            animation="blur"
            stagger={12}
            delay={300}
          />
        </div>
        <aside class="launch-aside" data-reveal>
          <span class="launch-aside__symbol" aria-hidden="true">※</span>
          <span class="launch-aside__text">Precios de lanzamiento</span>
          <span class="launch-aside__line" aria-hidden="true"></span>
        </aside>
      </div>
    </header>

    <!-- Level markers + Pricing lanes -->
    <div class="pricing-lanes" data-reveal-stagger>
      {tiers.flatMap((tier, i) => {
        const items = [];
        if (i === 0 || tier.level !== tiers[i - 1].level) {
          const labelMap = { puntual: 'Decisión puntual', estrategico: 'Sistema estratégico', continuo: 'Monitoreo continuo' };
          items.push(
            <div class="level-marker" aria-hidden="true">
              <span class="level-marker__dot" style={`background: ${tier.levelColor}`}></span>
              <span class="level-marker__label">{labelMap[tier.level]}</span>
              <span class="level-marker__line" style={`background: ${tier.levelColor}`}></span>
            </div>
          );
        }
        items.push(
          <article
            class={`pricing-lane ${tier.featured ? 'pricing-lane--featured' : ''}`}
            data-level={tier.level}
            role="button"
            tabindex="0"
            aria-expanded="false"
            aria-label={`${tier.name} — ${tier.tag} — USD ${tier.price}`}
            data-reveal
            data-cursor-grow
          >
            <div class="pricing-lane__left">
              <span class="pricing-lane__num" style={`color: ${tier.levelColor}`}>{tier.num}</span>
              <span class="pricing-lane__tag">{tier.tag}</span>
            </div>


          <div class="pricing-lane__center">
            <h3 class="pricing-lane__name">{tier.name}</h3>
            <div class="pricing-lane__expand">
              <p class="pricing-lane__headline" set:html={tier.headline} />
              {tier.benefit && <p class="pricing-lane__benefit">{tier.benefit}</p>}
              <p class="pricing-lane__body">{tier.body}</p>
              <ul class="pricing-lane__includes">
                {tier.includes.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>

          <div class="pricing-lane__right">
            <span class="pricing-lane__launch-badge">launch</span>
            <span class="pricing-lane__price" data-count-target={`USD ${tier.price}`}>USD {tier.price}</span>
            <span class="pricing-lane__time">{tier.time}</span>
          </div>

          <span class="pricing-lane__toggle" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path class="toggle-h" d="M0 7h14" stroke="currentColor" stroke-width="1.5"/>
              <path class="toggle-v" d="M7 0v14" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </span>
        </article>
        );
        return items;
      })}
    </div>

    <!-- Bottom CTA -->
    <div class="services-cta" data-reveal>
      <a class="button button-primary" href={bookingUrl} target="_blank" rel="noreferrer">
        Conversemos sobre tu caso <span aria-hidden="true">→</span>
      </a>
    </div>

  </div>
</section>

<style>
  .services-section {
    padding-block: var(--space-section);
  }

  .services-container {
    max-width: var(--max-w-content);
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 3vw, 3rem);
  }

  /* --- Header --- */

  .services-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
    margin-bottom: clamp(4rem, 5vw, 7rem);
  }

  .services-header__kicker {
    padding-top: 0.3em;
  }

  .section-index {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .services-header__title h2 {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 700;
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
    max-width: 24ch;
  }

  .services-header__title h2 em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
  }

  .services-header__copy {
    margin-top: 1.25rem;
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 48ch;
  }

  /* --- Launch aside (header) --- */

  .launch-aside {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: clamp(1.5rem, 2vw, 2.5rem);
  }

  .launch-aside__symbol {
    font-family: var(--font-display);
    font-size: 0.9rem;
    color: var(--foresight-teal);
    line-height: 1;
  }

  .launch-aside__text {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .launch-aside__line {
    flex: 1;
    height: 1px;
    background: var(--foresight-teal);
    opacity: 0.2;
    max-width: 8rem;
  }

  /* --- Level markers --- */

  .level-marker {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: clamp(0.8rem, 1.2vw, 1.2rem) 0;
  }

  .level-marker__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .level-marker__label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .level-marker__line {
    flex: 1;
    height: 1px;
    opacity: 0.18;
  }

  /* --- Pricing lanes --- */

  .pricing-lanes {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .pricing-lane {
    display: grid;
    grid-template-columns: clamp(6rem, 9vw, 9rem) 1fr auto;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
    padding-block: clamp(2rem, 3vw, 3.5rem);
    border-bottom: 1px solid var(--line);
    cursor: pointer;
    position: relative;
    outline: none;
    transition: background-color 0.3s ease;
  }

  .pricing-lane:hover,
  .pricing-lane:focus-visible {
    background: rgba(72, 101, 255, 0.02);
  }

  .pricing-lane:focus-visible {
    outline: 2px solid var(--signal-blue);
    outline-offset: -2px;
  }

  /* Featured tier accent */
  .pricing-lane--featured {
    border-left: 3px solid var(--signal-red);
    padding-left: clamp(1.5rem, 2vw, 2.5rem);
    margin-left: -3px;
  }

  .pricing-lane--featured .pricing-lane__name {
    color: var(--signal-red);
  }

  /* --- Left column: num + tag --- */

  .pricing-lane__left {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-top: 0.15rem;
  }

  .pricing-lane__num {
    font-family: var(--font-mono);
    font-size: clamp(1.2rem, 0.9rem + 0.8vw, 1.7rem);
    font-weight: 500;
    letter-spacing: var(--tracking-mono);
    line-height: 1;
    transition: transform 0.5s var(--ease-spring), opacity 0.4s ease;
  }

  .js .pricing-lane:not(.revealed) .pricing-lane__num {
    opacity: 0;
    transform: scale(1.3);
  }

  .js .pricing-lane.revealed .pricing-lane__num {
    opacity: 1;
    transform: scale(1);
  }

  .pricing-lane__tag {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    transition: color 0.3s ease;
  }

  .pricing-lane:hover .pricing-lane__tag {
    color: var(--ink-soft);
  }

  /* --- Center column: name + expandable content --- */

  .pricing-lane__name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1rem + 1.2vw, 2.4rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--ink);
    transition: color 0.3s ease;
    padding-right: 2.5rem;
  }

  .pricing-lane:hover .pricing-lane__name {
    color: var(--signal-red);
  }

  /* Expandable details */
  .pricing-lane__expand {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 0.5s var(--ease-out-expo),
      opacity 0.4s var(--ease-out-expo),
      margin-top 0.4s var(--ease-out-expo);
    margin-top: 0;
  }

  .pricing-lane__expand > * {
    overflow: hidden;
  }

  .pricing-lane.is-open .pricing-lane__expand {
    grid-template-rows: 1fr;
    opacity: 1;
    margin-top: clamp(0.8rem, 1.2vw, 1.2rem);
  }

  .pricing-lane__headline {
    font-family: var(--font-display);
    font-size: clamp(1rem, 0.9rem + 0.3vw, 1.2rem);
    font-weight: 500;
    line-height: 1.3;
    color: var(--ink);
    margin-bottom: 0.6rem;
  }

  .pricing-lane__headline em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
    color: var(--signal-red);
  }

  .pricing-lane__benefit {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: var(--leading-body);
    color: var(--ink);
    max-width: 52ch;
    margin-bottom: 0.5rem;
  }

  .pricing-lane__body {
    font-size: var(--text-sm);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 52ch;
    margin-bottom: 0.8rem;
  }

  .pricing-lane__includes {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .pricing-lane__includes li {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding: 0.35rem 0.6rem;
    border-radius: var(--radius-full);
    background: rgba(17, 17, 17, 0.04);
    border: 1px solid rgba(17, 17, 17, 0.06);
  }

  /* --- Right column: price + time --- */

  .pricing-lane__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    padding-top: 0.15rem;
  }

  .pricing-lane__launch-badge {
    font-family: var(--font-mono);
    font-size: 0.56rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--foresight-teal);
    border: 1px solid var(--foresight-teal-dim);
    border-radius: var(--radius-full);
    padding: 0.18rem 0.55rem;
    line-height: 1;
    align-self: flex-end;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .pricing-lane:hover .pricing-lane__launch-badge {
    opacity: 1;
  }

  .pricing-lane__price {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 0.8rem + 0.5vw, 1.3rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .pricing-lane__time {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  /* --- Toggle icon --- */

  .pricing-lane__toggle {
    position: absolute;
    top: clamp(2rem, 3vw, 3.5rem);
    right: 0;
    color: var(--ink-faint);
    transition: color 0.3s ease;
  }

  .pricing-lane__toggle .toggle-v {
    transition: transform 0.4s var(--ease-out-expo);
    transform-origin: center;
  }

  .pricing-lane.is-open .pricing-lane__toggle .toggle-v {
    transform: scaleY(0);
  }

  .pricing-lane:hover .pricing-lane__toggle {
    color: var(--signal-red);
  }

  /* --- Bottom CTA --- */

  .services-cta {
    display: flex;
    justify-content: center;
    margin-top: clamp(3rem, 4vw, 5rem);
  }

  /* --- Responsive --- */

  @media (max-width: 900px) {
    .services-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 700px) {
    .pricing-lane {
      grid-template-columns: auto 1fr;
      gap: 1rem;
    }

    .pricing-lane__right {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: baseline;
      gap: 1rem;
    }

    .pricing-lane__name {
      padding-right: 2rem;
    }
  }

  /* --- Reduced Motion --- */

  @media (prefers-reduced-motion: reduce) {
    .pricing-lane,
    .pricing-lane__expand,
    .pricing-lane__toggle .toggle-v {
      transition: none;
    }

    .js .pricing-lane:not(.revealed) .pricing-lane__num {
      opacity: 1;
      transform: none;
    }

    .pricing-lane__expand {
      grid-template-rows: 1fr;
      opacity: 1;
    }
  }
</style>

<script>
  /* === Pricing lanes: expand/collapse + counter === */
  (() => {
    const lanes = document.querySelectorAll<HTMLElement>('.pricing-lane');
    const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

    const toggleLane = (lane: HTMLElement) => {
      const wasOpen = lane.classList.contains('is-open');
      lanes.forEach((l) => {
        l.classList.remove('is-open');
        l.setAttribute('aria-expanded', 'false');
      });
      if (!wasOpen) {
        lane.classList.add('is-open');
        lane.setAttribute('aria-expanded', 'true');
      }
    };

    lanes.forEach((lane) => {
      lane.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggleLane(lane);
        }
      });

      if (isTouchDevice) {
        lane.addEventListener('click', () => toggleLane(lane));
      } else {
        lane.addEventListener('mouseenter', () => {
          lanes.forEach((l) => l.classList.remove('is-open'));
          lane.classList.add('is-open');
        });
        lane.addEventListener('mouseleave', () => {
          lane.classList.remove('is-open');
        });
      }
    });

    // Counter animation on prices
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const counters = document.querySelectorAll<HTMLElement>('[data-count-target]');
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const raw = el.dataset.countTarget || '';
        const match = raw.match(/([\d,]+)/);
        if (!match) return;
        const target = parseInt(match[1].replace(/,/g, ''), 10);
        const prefix = raw.slice(0, raw.indexOf(match[1]));
        const suffix = raw.slice(raw.indexOf(match[1]) + match[1].length);
        const duration = 1200;
        const start = performance.now();

        const tick = (now: number) => {
          const t = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - t, 4);
          const current = Math.round(target * ease);
          el.textContent = prefix + current.toLocaleString('en-US') + suffix;
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        counterObserver.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach((c) => counterObserver.observe(c));
  })();
</script>
