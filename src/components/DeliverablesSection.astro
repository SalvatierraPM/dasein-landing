---
const services = [
  {
    num: '01',
    name: 'Lectura de Campo',
    tag: 'Entry point',
    headline: 'Leer el sistema antes de intervenir.',
    body: 'Escaneamos señales, mapeamos actores y devolvemos una lectura sistémica del entorno que permite decidir con contexto real — no con intuición ni con datos genéricos.',
    entregables: [
      'Reporte de señales procesadas',
      'Mapa de actores con incentivos y fricciones',
    ],
    investment: 'Desde USD 2,500',
    duration: '5 días',
  },
  {
    num: '02',
    name: 'Simulación Estratégica',
    tag: 'Core',
    headline: 'Explorar futuros antes de comprometer recursos.',
    body: 'Simulación multiagente con memoria, incentivos y restricciones del caso real. No predecimos: exploramos comportamientos plausibles para que el equipo decida con escenarios, no con supuestos.',
    entregables: [
      'Dossier de escenarios con trazabilidad argumental',
      'Trail de evidencia: cada recomendación apunta a su señal',
      'Plan a 90 días con hitos y señales de alerta',
      'Workshop ejecutivo de cierre',
    ],
    investment: 'Desde USD 12,000',
    duration: '4–5 semanas',
  },
];

const calendlyUrl = 'https://calendly.com/salvatierra-pablom/30min';
---

<section class="services-section" id="servicios">
  <div class="services-container">

    <!-- Section header -->
    <header class="services-header" data-reveal>
      <div class="services-header__kicker">
        <span class="section-index">04 / Servicios</span>
      </div>
      <div class="services-header__title">
        <h2>Dos formatos según la profundidad <em>que necesites.</em></h2>
        <p class="services-header__copy">
          Cada servicio deja artefactos revisables. No vendemos horas de consultoría:
          vendemos piezas que un equipo puede usar para decidir.
        </p>
      </div>
    </header>

    <!-- Service cards -->
    <div class="services-grid" data-reveal-stagger>
      {services.map((svc) => (
        <article class="service-card" data-reveal>
          <div class="service-card__head">
            <span class="service-card__num">{svc.num}</span>
            <span class="service-card__tag">{svc.tag}</span>
          </div>
          <h3 class="service-card__name">{svc.name}</h3>
          <p class="service-card__headline">{svc.headline}</p>
          <p class="service-card__body">{svc.body}</p>

          <div class="service-card__entregables">
            <span class="service-card__entregables-label">Entregables</span>
            <ul>
              {svc.entregables.map((e) => (
                <li>{e}</li>
              ))}
            </ul>
          </div>

          <div class="service-card__footer">
            <div class="service-card__meta">
              <span class="service-card__investment">{svc.investment}</span>
              <span class="service-card__duration">{svc.duration}</span>
            </div>
            <a class="button button-primary service-card__cta" href={calendlyUrl} target="_blank" rel="noreferrer">
              Conversemos <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Partner CTA -->
    <div class="partner-block" data-reveal>
      <div class="partner-block__inner">
        <div class="partner-block__content">
          <span class="service-card__num">03</span>
          <h3 class="partner-block__title">¿Implementás estrategia, transformación o IA?</h3>
          <p class="partner-block__body">
            Dasein modela el sistema. Vos desplegás la solución. Buscamos consultoras, firmas de
            producto y equipos de implementación que quieran recibir un mapa estratégico listo
            para ejecutar.
          </p>
        </div>
        <div class="partner-block__action">
          <span class="partner-block__tag">Become a partner</span>
          <a class="button button-secondary partner-block__cta" href={calendlyUrl} target="_blank" rel="noreferrer">
            Hablemos <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .services-section {
    padding-block: var(--space-section);
  }

  .services-container {
    max-width: var(--max-w-content);
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 3vw, 3rem);
  }

  /* --- Header --- */

  .services-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
    margin-bottom: clamp(4rem, 5vw, 7rem);
  }

  .services-header__kicker {
    padding-top: 0.3em;
  }

  .section-index {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .services-header__title h2 {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 700;
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
    max-width: 22ch;
  }

  .services-header__title h2 em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
  }

  .services-header__copy {
    margin-top: 1.25rem;
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 48ch;
  }

  /* --- Service cards grid --- */

  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 1.5vw, 1.5rem);
    padding: clamp(2.5rem, 3.5vw, 4rem);
    border-bottom: 1px solid var(--line);
    position: relative;
  }

  .service-card:first-child {
    border-right: 1px solid var(--line);
  }

  /* --- Card head --- */

  .service-card__head {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .service-card__num {
    font-family: var(--font-mono);
    font-size: clamp(1.4rem, 1rem + 1vw, 2rem);
    font-weight: 500;
    letter-spacing: var(--tracking-mono);
    line-height: 1;
    color: var(--signal-red);
  }

  .service-card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: 2px;
  }

  /* --- Card content --- */

  .service-card__name {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.2rem + 1.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
  }

  .service-card__headline {
    font-family: var(--font-editorial);
    font-style: italic;
    font-size: clamp(1.1rem, 1rem + 0.3vw, 1.3rem);
    line-height: 1.45;
    color: var(--signal-red);
    max-width: 32ch;
  }

  .service-card__body {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 44ch;
  }

  /* --- Entregables list --- */

  .service-card__entregables {
    padding-top: clamp(1rem, 1.5vw, 1.5rem);
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-card__entregables-label {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .service-card__entregables-label::before {
    content: '◈';
    color: var(--signal-blue);
    opacity: 0.6;
    margin-right: 0.3rem;
  }

  .service-card__entregables ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }

  .service-card__entregables li {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.02em;
    color: var(--ink-faint);
    padding-left: 1.4rem;
    position: relative;
  }

  .service-card__entregables li::before {
    content: '※';
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--signal-blue);
    opacity: 0.6;
  }

  /* --- Card footer --- */

  .service-card__footer {
    margin-top: auto;
    padding-top: clamp(1.5rem, 2vw, 2rem);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .service-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .service-card__investment {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 0.8rem + 0.5vw, 1.3rem);
    font-weight: 600;
    letter-spacing: var(--tracking-mono);
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }

  .service-card__duration {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .service-card__cta {
    flex-shrink: 0;
  }

  /* --- Partner block --- */

  .partner-block {
    margin-top: clamp(3rem, 4vw, 5rem);
  }

  .partner-block__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(3rem, 4vw, 5rem);
    align-items: center;
    padding: clamp(2.5rem, 3.5vw, 4rem);
    border: 1px solid var(--line);
    border-radius: 4px;
    background: rgba(17, 17, 17, 0.02);
  }

  .partner-block__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .partner-block__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1rem + 1vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
    max-width: 28ch;
  }

  .partner-block__body {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 50ch;
  }

  .partner-block__action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .partner-block__tag {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .partner-block__tag::before {
    content: '→';
    color: var(--signal-red);
    opacity: 0.6;
    margin-right: 0.4rem;
  }

  /* --- Responsive --- */

  @media (max-width: 900px) {
    .services-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 860px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card:first-child {
      border-right: none;
    }

    .service-card {
      padding: clamp(2rem, 3vw, 3rem) 0;
    }

    .service-card__footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .service-card__cta {
      width: 100%;
      text-align: center;
    }

    .partner-block__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .partner-block__action {
      align-items: flex-start;
    }

    .partner-block__cta {
      width: 100%;
      text-align: center;
    }

    .services-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  /* --- Reduced Motion --- */

  @media (prefers-reduced-motion: reduce) {
    .service-card,
    .partner-block__inner {
      transition: none;
    }
  }
</style>
