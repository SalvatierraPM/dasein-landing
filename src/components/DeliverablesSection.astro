---
import TextSplitter from './TextSplitter.astro';

const services = [
  {
    num: '01',
    name: 'Lectura de Campo',
    tag: 'Entry point',
    headline: 'Entender qué está pasando <em>antes de actuar.</em>',
    body: 'Escaneamos señales regulatorias, competitivas y tecnológicas. Mapeamos quién juega y qué quiere. Te devolvemos un reporte con lo que otros <em>no están viendo.</em>',
    entregables: [
      'Reporte de señales procesadas',
      'Mapa de actores con incentivos y fricciones',
    ],
    investment: 'Desde USD 4,500',
    duration: '7 días',
    ghost: '→',
  },
  {
    num: '02',
    name: 'Simulación Estratégica',
    tag: 'Core',
    headline: 'Simular cómo reaccionan los actores <em>antes de que tú actúes.</em>',
    body: 'Simulamos cómo se comportarían los actores clave — reguladores, competidores, aliados — frente a cada decisión que podrías tomar. Cada recomendación viene con <em>su evidencia.</em>',
    entregables: [
      'Dossier de escenarios con evidencia trazable',
      'Cada recomendación apunta a su señal de origen',
      'Plan a 90 días con hitos y señales de alerta',
      'Workshop ejecutivo de cierre',
    ],
    investment: 'Desde USD 18,000',
    duration: '5–6 semanas',
    ghost: '◈',
  },
];

const calendlyUrl = 'https://calendly.com/salvatierra-pablom/30min';
---

<section class="services-section" id="servicios">
  <div class="services-container">

    <!-- Section header -->
    <header class="services-header" data-reveal>
      <div class="services-header__kicker">
        <span class="section-index">01 / Servicios</span>
      </div>
      <div class="services-header__title" data-line-reveal>
        <h2>Uno lee el terreno. El otro simula <em>lo que viene.</em></h2>
        <div class="services-header__copy">
          <TextSplitter
            text="No vendemos horas de consultoría. Vendemos entregables que un directorio puede usar para decidir."
            tag="p"
            animation="blur"
            stagger={12}
            delay={300}
          />
        </div>
      </div>
    </header>

    <!-- Service cards -->
    <div class="services-grid" data-reveal-stagger>
      {services.map((svc) => (
        <article class="service-card" data-reveal>
          <span class="service-card__ghost" aria-hidden="true">{svc.ghost}</span>
          <div class="service-card__head">
            <span class="service-card__num">{svc.num}</span>
            <span class="service-card__tag">{svc.tag}</span>
          </div>
          <h3 class="service-card__name">{svc.name}</h3>
          <p class="service-card__headline" set:html={svc.headline} />
          <p class="service-card__body" set:html={svc.body} />

          <div class="service-card__entregables">
            <span class="service-card__entregables-label">Entregables</span>
            <ul>
              {svc.entregables.map((e) => (
                <li>{e}</li>
              ))}
            </ul>
          </div>

          <div class="service-card__footer">
            <div class="service-card__meta">
              <span class="service-card__investment" data-count-target={svc.investment}>{svc.investment}</span>
              <span class="service-card__duration">{svc.duration}</span>
            </div>
            <a class="button button-primary service-card__cta" href={calendlyUrl} target="_blank" rel="noreferrer">
              Conversemos <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Radar Estratégico — partnership model -->
    <div class="partner-block" data-scale-in>
      <div class="partner-block__inner">
        <span class="service-card__ghost" aria-hidden="true">◇</span>
        <div class="partner-block__content">
          <span class="service-card__num">03</span>
          <h3 class="partner-block__title">Radar Estratégico — <em>monitoreo continuo.</em></h3>
          <p class="partner-block__body">
            Para organizaciones que necesitan vigilancia permanente: escaneo mensual,
            re-simulación trimestral, alertas calibradas y reportes <em>board-ready.</em>
            Diseñado como partnership a medida.
          </p>
          <span class="partner-block__price">Desde USD 7,500/mes · mínimo 3 meses</span>
        </div>
        <div class="partner-block__action">
          <span class="partner-block__tag">Partnership</span>
          <a class="button button-secondary partner-block__cta" href={calendlyUrl} target="_blank" rel="noreferrer">
            Conversemos <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .services-section {
    padding-block: var(--space-section);
  }

  .services-container {
    max-width: var(--max-w-content);
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 3vw, 3rem);
  }

  /* --- Header --- */

  .services-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
    margin-bottom: clamp(4rem, 5vw, 7rem);
  }

  .services-header__kicker {
    padding-top: 0.3em;
  }

  .section-index {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .services-header__title h2 {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 700;
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
    max-width: 22ch;
  }

  .services-header__title h2 em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
  }

  .services-header__copy {
    margin-top: 1.25rem;
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 48ch;
  }

  /* --- Service cards grid --- */

  .services-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--line);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 1.5vw, 1.5rem);
    padding: clamp(2.5rem, 3.5vw, 4rem);
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  /* Scroll-driven entrance: clip-path wipe + tilt */
  .js .service-card {
    opacity: 0;
    clip-path: inset(0 100% 0 0);
    transform: translateX(-24px);
    transition: opacity 0.9s var(--ease-out-expo),
                clip-path 0.9s var(--ease-out-expo),
                transform 0.9s var(--ease-out-expo);
  }

  .js .service-card.is-scrolled-in {
    opacity: 1;
    clip-path: inset(0 0 0 0);
    transform: translateX(0);
  }

  .js .service-card:nth-child(2) {
    transition-delay: 0.2s;
    clip-path: inset(0 0 0 100%);
    transform: translateX(24px);
  }

  .js .service-card:nth-child(2).is-scrolled-in {
    clip-path: inset(0 0 0 0);
    transform: translateX(0);
  }

  .service-card__ghost {
    position: absolute;
    top: 0.5rem;
    right: 1rem;
    font-family: var(--font-mono);
    font-size: clamp(5rem, 4rem + 4vw, 9rem);
    font-weight: 600;
    line-height: 1;
    color: var(--ink);
    opacity: 0.035;
    user-select: none;
    pointer-events: none;
    z-index: 0;
  }

  .service-card:first-child {
    border-right: 1px solid var(--line);
  }

  /* --- Card head --- */

  .service-card__head {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .service-card__num {
    font-family: var(--font-mono);
    font-size: clamp(1.4rem, 1rem + 1vw, 2rem);
    font-weight: 500;
    letter-spacing: var(--tracking-mono);
    line-height: 1;
    color: var(--signal-red);
  }

  .service-card__tag {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--line);
    border-radius: 2px;
  }

  /* --- Card content --- */

  .service-card__name {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.2rem + 1.5vw, 2.8rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
  }

  .service-card__headline {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1rem + 0.5vw, 1.5rem);
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--ink);
    max-width: 32ch;
  }

  .service-card__headline em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
    color: var(--signal-red);
  }

  .service-card__body {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 44ch;
  }

  .service-card__body em {
    font-family: var(--font-editorial);
    font-style: italic;
    color: var(--ink);
  }

  /* --- Entregables list --- */

  .service-card__entregables {
    padding-top: clamp(1rem, 1.5vw, 1.5rem);
    border-top: 1px solid var(--line);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-card__entregables-label {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .service-card__entregables-label::before {
    content: '◈';
    color: var(--signal-blue);
    opacity: 0.6;
    margin-right: 0.3rem;
  }

  .service-card__entregables ul {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }

  .service-card__entregables li {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.02em;
    color: var(--ink-faint);
    padding-left: 1.4rem;
    position: relative;
  }

  .service-card__entregables li::before {
    content: '※';
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--signal-blue);
    opacity: 0.6;
  }

  /* --- Card footer --- */

  .service-card__footer {
    margin-top: auto;
    padding-top: clamp(1.5rem, 2vw, 2rem);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
  }

  .service-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .service-card__investment {
    font-family: var(--font-mono);
    font-size: clamp(1rem, 0.8rem + 0.5vw, 1.3rem);
    font-weight: 600;
    letter-spacing: var(--tracking-mono);
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }

  .service-card__duration {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .service-card__cta {
    flex-shrink: 0;
  }

  /* --- Partner block --- */

  .partner-block {
    margin-top: clamp(3rem, 4vw, 5rem);
  }

  .partner-block__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(3rem, 4vw, 5rem);
    align-items: center;
    padding: clamp(2.5rem, 3.5vw, 4rem);
    border: 1px solid var(--line);
    border-radius: 4px;
    background: rgba(17, 17, 17, 0.02);
    position: relative;
    overflow: hidden;
  }

  .partner-block__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .partner-block__title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1rem + 1vw, 2rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
    max-width: 28ch;
  }

  .partner-block__title em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
    color: var(--signal-red);
  }

  .partner-block__body em {
    font-family: var(--font-editorial);
    font-style: italic;
    color: var(--ink);
  }

  .partner-block__price {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--signal-blue);
    margin-top: 0.25rem;
  }

  .partner-block__body {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 50ch;
  }

  .partner-block__action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .partner-block__tag {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .partner-block__tag::before {
    content: '→';
    color: var(--signal-red);
    opacity: 0.6;
    margin-right: 0.4rem;
  }

  /* --- Responsive --- */

  @media (max-width: 900px) {
    .services-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 860px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card:first-child {
      border-right: none;
    }

    .service-card {
      padding: clamp(2rem, 3vw, 3rem) 0;
    }

    .service-card__footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .service-card__cta {
      width: 100%;
      text-align: center;
    }

    .partner-block__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .partner-block__action {
      align-items: flex-start;
    }

    .partner-block__cta {
      width: 100%;
      text-align: center;
    }

    .services-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  /* --- Card entrance with scale --- */

  [data-reveal-stagger] .service-card {
    transform: translateY(24px) scale(0.97);
    opacity: 0;
    transition: transform 0.6s var(--ease-out-expo), opacity 0.5s var(--ease-out-expo);
  }

  [data-reveal-stagger].revealed .service-card {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  [data-reveal-stagger].revealed .service-card:nth-child(2) {
    transition-delay: 0.12s;
  }

  /* --- Card hover glow --- */

  .service-card {
    transition: border-color 0.4s var(--ease-spring), box-shadow 0.4s var(--ease-spring), transform 0.4s var(--ease-spring);
  }

  .service-card:hover {
    border-color: rgba(72, 101, 255, 0.25);
    box-shadow: 0 8px 32px rgba(72, 101, 255, 0.06), 0 0 0 1px rgba(72, 101, 255, 0.08);
    transform: translateY(-4px);
  }

  /* --- Reduced Motion --- */

  @media (prefers-reduced-motion: reduce) {
    .service-card,
    .partner-block__inner {
      transition: none;
    }

    [data-reveal-stagger] .service-card {
      transform: none;
      opacity: 1;
      transition: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .js .service-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  /* === Service cards: scroll-driven entrance + counter === */
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Card entrance with perspective tilt
    const cards = document.querySelectorAll('.service-card');
    const cardObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-scrolled-in');
          cardObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2, rootMargin: '0px 0px -8% 0px' });

    cards.forEach((card) => cardObserver.observe(card));

    // Counter animation on investment numbers
    const counters = document.querySelectorAll<HTMLElement>('[data-count-target]');
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const raw = el.dataset.countTarget || '';
        // Extract number: "Desde USD 4,500" → 4500
        const match = raw.match(/([\d,]+)/);
        if (!match) return;
        const target = parseInt(match[1].replace(/,/g, ''), 10);
        const prefix = raw.slice(0, raw.indexOf(match[1]));
        const suffix = raw.slice(raw.indexOf(match[1]) + match[1].length);
        const duration = 1200;
        const start = performance.now();

        const tick = (now: number) => {
          const t = Math.min((now - start) / duration, 1);
          const ease = 1 - Math.pow(1 - t, 4); // ease-out-quart
          const current = Math.round(target * ease);
          el.textContent = prefix + current.toLocaleString('en-US') + suffix;
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
        counterObserver.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach((c) => counterObserver.observe(c));
  })();
</script>
