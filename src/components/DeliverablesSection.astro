---
const deliverables = [
  {
    title: 'Dossier de escenarios',
    body: 'La pieza central: señales, actores, escenarios plausibles, implicancias y recomendaciones en un formato que se puede discutir.',
  },
  {
    title: 'Trail de evidencia',
    body: 'Cada decisión queda conectada a fuentes, supuestos y tensiones visibles. La auditabilidad no se agrega al final.',
  },
  {
    title: 'Plan a 90 días',
    body: 'El trabajo termina con un mapa de acción: qué monitorear, qué preparar y qué decisiones conviene secuenciar ahora.',
  },
];

---

<section class="deliverables-section" id="entregables">
  <div class="deliverables-container">

    <!-- Progress meter -->
    <div class="progress-meter" data-reveal>
      <span class="progress-meter__label">Explorados</span>
      <span class="progress-meter__count">
        <span class="progress-meter__current" id="deliv-explored">0</span>/<span>3</span>
      </span>
      <div class="progress-meter__track">
        <div class="progress-meter__fill" id="deliv-fill"></div>
      </div>
    </div>

    <!-- Section header — asymmetric 2-col -->
    <header class="deliverables-header" data-reveal>
      <div class="deliverables-header__kicker">
        <span class="section-index">05 / Entregables</span>
      </div>
      <div class="deliverables-header__title">
        <h2>La credibilidad entra por lo que se entrega, <em>no por la promesa.</em></h2>
        <p class="deliverables-header__copy">
          Dasein no termina en una lectura elegante. Termina en piezas que un equipo directivo puede
          usar para discutir escenarios, monitorear señales y ordenar decisiones concretas.
        </p>
      </div>
    </header>

    <!-- Deliverable chapters -->
    <div class="deliverables-list" data-reveal-stagger>
      {deliverables.map((item, i) => (
        <article
          class="deliverable-chapter"
          data-chapter
          tabindex="0"
          role="button"
          aria-expanded="false"
          aria-controls={`deliv-body-${i}`}
        >
          <div class="deliverable-chapter__left">
            <span class="deliverable-chapter__watermark" aria-hidden="true">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="deliverable-chapter__title">
              <span class="deliverable-chapter__number">
                {String(i + 1).padStart(2, '0')}
              </span>
              {item.title}
            </h3>
          </div>
          <div class="deliverable-chapter__right">
            <div class="deliverable-chapter__body-wrapper" id={`deliv-body-${i}`}>
              <div class="deliverable-chapter__body">
                <p>{item.body}</p>
              </div>
            </div>
            <span class="deliverable-chapter__toggle" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <line class="toggle-h" x1="4" y1="10" x2="16" y2="10" stroke="currentColor" stroke-width="1.5" />
                <line class="toggle-v" x1="10" y1="4" x2="10" y2="16" stroke="currentColor" stroke-width="1.5" />
              </svg>
            </span>
          </div>
        </article>
      ))}
    </div>

    <div class="deliv-cta-row" data-reveal>
      <a class="button button-primary" data-cta href="#contacto">Conversemos sobre tu caso</a>
    </div>

  </div>
</section>

<script>
  function initDeliverables() {
    const chapters = document.querySelectorAll<HTMLElement>('[data-chapter]');
    const explored = new Set<number>();
    const currentEl = document.getElementById('deliv-explored');
    const fillEl = document.getElementById('deliv-fill');
    const stripEl = document.getElementById('includes-strip');

    function updateProgress() {
      if (!currentEl || !fillEl) return;
      const count = explored.size;
      currentEl.textContent = String(count);
      fillEl.style.transform = `scaleX(${count / 3})`;

      if (count === 3 && stripEl) {
        stripEl.classList.add('all-explored');
      }
    }

    function openChapter(chapter: HTMLElement, index: number) {
      chapter.setAttribute('aria-expanded', 'true');
      chapter.classList.add('is-open');
      explored.add(index);
      updateProgress();
    }

    function closeChapter(chapter: HTMLElement) {
      chapter.setAttribute('aria-expanded', 'false');
      chapter.classList.remove('is-open');
    }

    const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

    chapters.forEach((chapter, index) => {
      if (isTouchDevice) {
        chapter.addEventListener('click', () => {
          const isOpen = chapter.classList.contains('is-open');
          chapters.forEach((c) => closeChapter(c));
          if (!isOpen) openChapter(chapter, index);
        });
      } else {
        chapter.addEventListener('mouseenter', () => {
          chapters.forEach((c) => closeChapter(c));
          openChapter(chapter, index);
        });
        chapter.addEventListener('mouseleave', () => {
          closeChapter(chapter);
        });
      }

      chapter.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const isOpen = chapter.classList.contains('is-open');
          chapters.forEach((c) => closeChapter(c));
          if (!isOpen) openChapter(chapter, index);
        }
      });
    });
  }

  // Run on initial load and after Astro view transitions
  document.addEventListener('astro:page-load', initDeliverables);
  if (!document.querySelector('[data-astro-transition]')) {
    initDeliverables();
  }
</script>

<style>
  /* ========================================
     Deliverables Section
     ======================================== */

  .deliverables-section {
    padding-block: var(--space-section);
  }

  .deliverables-container {
    max-width: var(--max-w-content);
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 3vw, 3rem);
  }

  /* --- Progress Meter --- */

  .progress-meter {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: clamp(3rem, 4vw, 5rem);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: var(--tracking-mono);
    color: var(--ink-faint);
    text-transform: uppercase;
  }

  .progress-meter__count {
    color: var(--ink-soft);
    font-variant-numeric: tabular-nums;
  }

  .progress-meter__current {
    color: var(--signal-blue);
    font-weight: 600;
  }

  .progress-meter__track {
    width: 4rem;
    height: 2px;
    background: var(--line);
    overflow: hidden;
  }

  .progress-meter__fill {
    width: 100%;
    height: 100%;
    background: var(--signal-blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s var(--ease-out-expo);
  }

  /* --- Section Header --- */

  .deliverables-header {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(2rem, 4vw, 5rem);
    align-items: start;
    margin-bottom: clamp(4rem, 5vw, 7rem);
  }

  .deliverables-header__kicker {
    padding-top: 0.3em;
  }

  .section-index {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .deliverables-header__title h2 {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 600;
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
    max-width: 22ch;
  }

  .deliverables-header__title h2 em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
  }

  .deliverables-header__copy {
    margin-top: 1.25rem;
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 48ch;
  }

  /* --- Deliverable Chapters --- */

  .deliverables-list {
    border-top: 1px solid var(--line);
  }

  .deliverable-chapter {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 3vw, 4rem);
    align-items: start;
    padding-block: clamp(2.5rem, 3.5vw, 4.5rem);
    border-bottom: 1px solid var(--line);
    cursor: pointer;
    position: relative;
    outline: none;
  }

  .deliverable-chapter:focus-visible {
    outline: 2px solid var(--signal-blue);
    outline-offset: -2px;
  }

  /* Left column: number + title */

  .deliverable-chapter__left {
    position: relative;
    overflow: hidden;
  }

  .deliverable-chapter__watermark {
    position: absolute;
    top: -0.15em;
    left: -0.05em;
    font-family: var(--font-mono);
    font-size: clamp(3rem, 2rem + 3vw, 5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--ink);
    opacity: 0.06;
    transition: transform 0.6s var(--ease-out-expo);
    user-select: none;
    pointer-events: none;
  }

  .deliverable-chapter:hover .deliverable-chapter__watermark,
  .deliverable-chapter:focus-visible .deliverable-chapter__watermark {
    transform: translateX(6px);
  }

  .deliverable-chapter__title {
    position: relative;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 1.2rem + 1vw, 2.4rem);
    font-weight: 600;
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
    transition: color 0.4s var(--ease-out-expo);
    padding-top: 0.2em;
  }

  .deliverable-chapter:hover .deliverable-chapter__title,
  .deliverable-chapter:focus-visible .deliverable-chapter__title {
    color: oklch(45% 0.08 40);
  }

  .deliverable-chapter__number {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    font-weight: 500;
    letter-spacing: var(--tracking-overline);
    color: var(--ink-faint);
    margin-bottom: 0.6rem;
    transition: color 0.4s var(--ease-out-expo);
  }

  .deliverable-chapter:hover .deliverable-chapter__number,
  .deliverable-chapter:focus-visible .deliverable-chapter__number {
    color: oklch(45% 0.08 40);
  }

  /* Right column: expandable body + toggle */

  .deliverable-chapter__right {
    display: flex;
    align-items: start;
    gap: 1.5rem;
    padding-top: 0.2em;
  }

  .deliverable-chapter__body-wrapper {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.5s var(--ease-out-expo);
    overflow: hidden;
    flex: 1;
  }

  .deliverable-chapter.is-open .deliverable-chapter__body-wrapper {
    grid-template-rows: 1fr;
  }

  .deliverable-chapter__body {
    min-height: 0;
    overflow: hidden;
  }

  .deliverable-chapter__body p {
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--ink-soft);
    max-width: 44ch;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.4s var(--ease-out-expo) 0.1s,
      transform 0.4s var(--ease-out-expo) 0.1s;
    padding-bottom: 0.25rem;
  }

  .deliverable-chapter.is-open .deliverable-chapter__body p {
    opacity: 1;
    transform: translateY(0);
  }

  /* Toggle icon */

  .deliverable-chapter__toggle {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--line);
    border-radius: 50%;
    color: var(--ink-faint);
    transition:
      color 0.3s var(--ease-out-expo),
      border-color 0.3s var(--ease-out-expo),
      transform 0.3s var(--ease-out-expo);
    margin-top: 0.6rem;
  }

  .deliverable-chapter:hover .deliverable-chapter__toggle,
  .deliverable-chapter:focus-visible .deliverable-chapter__toggle {
    color: oklch(45% 0.08 40);
    border-color: oklch(45% 0.08 40 / 0.3);
  }

  .deliverable-chapter__toggle .toggle-v {
    transition: transform 0.4s var(--ease-out-expo);
    transform-origin: center;
  }

  .deliverable-chapter.is-open .deliverable-chapter__toggle .toggle-v {
    transform: scaleY(0);
  }

  .deliverable-chapter.is-open .deliverable-chapter__toggle {
    transform: rotate(0deg);
    color: oklch(45% 0.08 40);
    border-color: oklch(45% 0.08 40 / 0.3);
  }

  /* --- Includes Strip --- */

  .includes-strip {
    margin-top: clamp(3rem, 4vw, 5rem);
    padding: clamp(1.75rem, 2.5vw, 2.5rem) clamp(2rem, 3vw, 3rem);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 4px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem 2.5rem;
    align-items: start;
    transition: border-color 0.8s var(--ease-out-expo);
  }

  .includes-strip.all-explored {
    border-color: rgba(72, 101, 255, 0.25);
  }

  .includes-strip__left {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .includes-strip__right {
    display: flex;
    align-items: start;
    padding-top: 0.15em;
  }

  .includes-strip__label {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .includes-strip__items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .includes-strip__pill {
    display: inline-block;
    padding: 0.35em 0.85em;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    letter-spacing: 0.02em;
    color: var(--ink-soft);
    background: rgba(17, 17, 17, 0.03);
    border: 1px solid var(--line);
    border-radius: 2px;
    white-space: nowrap;
    transition: border-color 0.3s var(--ease-out-expo);
  }

  .includes-strip.all-explored .includes-strip__pill {
    border-color: rgba(72, 101, 255, 0.3);
    color: var(--ink);
  }

  .includes-strip__note {
    font-size: var(--text-sm);
    line-height: var(--leading-body);
    color: var(--ink-faint);
    max-width: 48ch;
  }

  /* ========================================
     Responsive
     ======================================== */

  @media (max-width: 900px) {
    .deliverables-header {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .deliverable-chapter {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .deliverable-chapter__right {
      padding-left: 0;
    }

    .deliverable-chapter__watermark {
      font-size: clamp(2.5rem, 2rem + 2vw, 3.5rem);
    }

    .includes-strip {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .deliverable-chapter__toggle {
      width: 2rem;
      height: 2rem;
    }

    .deliverable-chapter__toggle svg {
      width: 16px;
      height: 16px;
    }
  }

  /* ========================================
     Reduced Motion
     ======================================== */

  @media (prefers-reduced-motion: reduce) {
    .deliverable-chapter__body p {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .deliverable-chapter__body-wrapper {
      grid-template-rows: 1fr;
    }

    .progress-meter__fill {
      transition: none;
    }

    .deliverable-chapter__watermark {
      transition: none;
    }

    .deliverable-chapter__toggle .toggle-v {
      transition: none;
    }
  }

  .deliv-cta-row {
    display: flex;
    justify-content: center;
    padding-top: clamp(3rem, 4vw, 5rem);
  }
</style>
