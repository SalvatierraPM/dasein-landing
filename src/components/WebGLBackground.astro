---
/**
 * WebGLBackground — Single fullscreen WebGL canvas with raymarched SDF shapes
 * that morph based on scroll progress. Replaces heavy Three.js particle systems.
 *
 * One draw call per frame. All computation on GPU via fragment shader.
 * Shapes: sphere → torus → box → octahedron → double-torus, blended by scroll.
 */
---

<canvas id="webgl-bg" aria-hidden="true"></canvas>

<style>
  #webgl-bg {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script>
  (() => {
    const canvas = document.getElementById('webgl-bg') as HTMLCanvasElement | null;
    if (!canvas) return;

    /* Respect reduced motion — remove canvas entirely */
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      canvas.remove();
      return;
    }

    const gl = canvas.getContext('webgl', { alpha: true, powerPreference: 'low-power' });
    if (!gl) {
      canvas.remove();
      return;
    }

    /* ── Shaders ── */
    const vertSrc = `attribute vec2 a; void main(){ gl_Position=vec4(a,0,1); }`;

    const fragSrc = `
precision highp float;
uniform vec2 uR;
uniform float uT, uS, uSc, uBl;
uniform vec3 uBg;

#define TAU 6.2831853

mat2 r2(float a) {
  float c = cos(a), s = sin(a);
  return mat2(c, -s, s, c);
}

float sphere(vec3 p, float r) { return length(p) - r; }

float torus(vec3 p, vec2 t) {
  vec2 q = vec2(length(p.xz) - t.x, p.y);
  return length(q) - t.y;
}

float box(vec3 p, vec3 b) {
  vec3 q = abs(p) - b;
  return length(max(q, 0.)) + min(max(q.x, max(q.y, q.z)), 0.);
}

float octa(vec3 p, float s) {
  p = abs(p);
  return (p.x + p.y + p.z - s) * .5773;
}

float sdf(vec3 p) {
  float t = uT * .25, sc = uSc, bl = uBl;

  /* Shape 1: breathing sphere */
  float d0 = sphere(p, .65 + .05 * sin(t * 1.3));

  /* Shape 2: rotating torus */
  vec3 p1 = p; p1.xz = r2(t * .6) * p1.xz;
  float d1 = torus(p1, vec2(.55, .22));

  /* Shape 3: tumbling box */
  vec3 p2 = p; p2.xy = r2(t * .4) * p2.xy; p2.yz = r2(t * .3) * p2.yz;
  float d2 = box(p2, vec3(.42 + .04 * sin(t * 2.)));

  /* Shape 4: spinning octahedron */
  vec3 p3 = p; p3.xy = r2(t * .5) * p3.xy;
  float d3 = octa(p3, .72 + .04 * sin(t * 1.7));

  /* Shape 5: interlocked double torus */
  vec3 p4 = p; p4.xz = r2(t * .7) * p4.xz;
  float d4a = torus(p4, vec2(.45, .15));
  vec3 p5 = p; p5.xy = r2(t * .5 + 1.2) * p5.xy;
  float d4b = torus(p5, vec2(.35, .12));
  float d4 = min(d4a, d4b);

  /* Blend between shapes based on scroll scene */
  if (sc < 1.) return mix(d0, d1, bl);
  if (sc < 2.) return mix(d1, d2, bl);
  if (sc < 3.) return mix(d2, d3, bl);
  return mix(d3, d4, bl);
}

vec3 norm(vec3 p) {
  float e = .001;
  return normalize(vec3(
    sdf(p + vec3(e,0,0)) - sdf(p - vec3(e,0,0)),
    sdf(p + vec3(0,e,0)) - sdf(p - vec3(0,e,0)),
    sdf(p + vec3(0,0,e)) - sdf(p - vec3(0,0,e))
  ));
}

/* Palette: blue → coral, Dasein brand tones */
vec3 pal(float t) {
  return .5 + .5 * cos(TAU * (.75 * t + vec3(.55, .65, .82)));
}

void main() {
  vec2 uv = (gl_FragCoord.xy - uR * .5) / min(uR.x, uR.y);
  vec3 ro = vec3(0, 0, 2.4);
  vec3 rd = normalize(vec3(uv, -1.2));

  float t = 0., hit = 0.;
  for (int i = 0; i < 80; i++) {
    float d = sdf(ro + rd * t);
    if (d < .001) { hit = 1.; break; }
    if (t > 6.) break;
    t += d;
  }

  vec3 bg = uBg, col = bg;

  if (hit > .5) {
    vec3 p = ro + rd * t;
    vec3 n = norm(p);
    vec3 bc = pal(uS);
    vec3 l = normalize(vec3(.7, 1., .5));
    float dif = clamp(dot(n, l), 0., 1.);
    float spe = pow(clamp(dot(reflect(-l, n), -rd), 0., 1.), 32.);
    float fr  = pow(1. - clamp(dot(-rd, n), 0., 1.), 3.5);
    col = bc * (dif * .7 + .3) + spe * .45 + fr * vec3(.28, .4, 1.) * .5;
    col = mix(bg, col, exp(-t * .15));
  }

  /* Vignette */
  col = mix(uBg, col, clamp(1. - dot(uv * .9, uv * .9), 0., 1.));

  /* Film grain */
  col += (fract(sin(dot(gl_FragCoord.xy, vec2(127.1, 311.7))) * 43758.5) - .5) * .02;

  gl_FragColor = vec4(col, 1.);
}`;

    /* ── Compile helpers ── */
    const mkShader = (type: number, src: string): WebGLShader | null => {
      const s = gl.createShader(type);
      if (!s) return null;
      gl.shaderSource(s, src);
      gl.compileShader(s);
      if (!gl.getShaderParameter(s, gl.COMPILE_STATUS)) {
        console.error('Shader compile error:', gl.getShaderInfoLog(s));
        gl.deleteShader(s);
        return null;
      }
      return s;
    };

    const vs = mkShader(gl.VERTEX_SHADER, vertSrc);
    const fs = mkShader(gl.FRAGMENT_SHADER, fragSrc);
    if (!vs || !fs) { canvas.remove(); return; }

    const prog = gl.createProgram()!;
    gl.attachShader(prog, vs);
    gl.attachShader(prog, fs);
    gl.linkProgram(prog);
    if (!gl.getProgramParameter(prog, gl.LINK_STATUS)) {
      console.error('Program link error:', gl.getProgramInfoLog(prog));
      canvas.remove();
      return;
    }
    gl.useProgram(prog);

    /* ── Fullscreen quad ── */
    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1,-1, 1,-1, -1,1, 1,1]), gl.STATIC_DRAW);
    const ap = gl.getAttribLocation(prog, 'a');
    gl.enableVertexAttribArray(ap);
    gl.vertexAttribPointer(ap, 2, gl.FLOAT, false, 0, 0);

    /* ── Uniforms ── */
    const uR    = gl.getUniformLocation(prog, 'uR');
    const uTime = gl.getUniformLocation(prog, 'uT');
    const uScrl = gl.getUniformLocation(prog, 'uS');
    const uScn  = gl.getUniformLocation(prog, 'uSc');
    const uBld  = gl.getUniformLocation(prog, 'uBl');
    const uBg   = gl.getUniformLocation(prog, 'uBg');

    /* Navy background — matches Dasein dark sections */
    gl.uniform3f(uBg, 0.059, 0.102, 0.18);

    /* ── Resize ── */
    const isMobile = window.innerWidth < 768 || 'ontouchstart' in window;
    const maxDpr = isMobile ? 1 : Math.min(devicePixelRatio ?? 1, 1.5);

    const resize = () => {
      canvas.width  = innerWidth * maxDpr;
      canvas.height = innerHeight * maxDpr;
      canvas.style.width  = `${innerWidth}px`;
      canvas.style.height = `${innerHeight}px`;
      gl.viewport(0, 0, canvas.width, canvas.height);
      gl.uniform2f(uR, canvas.width, canvas.height);
    };

    resize();
    window.addEventListener('resize', resize);

    /* ── Scroll tracking ── */
    const N = 5; /* number of SDF shapes */
    let tgt = 0;
    let smooth = 0;

    const getMaxScroll = () =>
      Math.max(1, document.documentElement.scrollHeight - innerHeight);

    window.addEventListener('scroll', () => {
      tgt = scrollY / getMaxScroll();
    }, { passive: true });

    /* ── Render loop ── */
    const t0 = performance.now();
    let lastNow = t0;
    let disposed = false;

    const frame = (now: number) => {
      if (disposed) return;
      requestAnimationFrame(frame);

      const dt = Math.min((now - lastNow) / 1000, 0.05);
      lastNow = now;

      /* Smooth scroll interpolation */
      smooth += (tgt - smooth) * (1 - Math.exp(-dt * 6));

      const raw = smooth * (N - 1);
      const flr = Math.floor(raw);
      const si  = Math.min(flr, N - 2);
      const bl  = flr >= N - 1 ? 1.0 : raw - flr;

      gl.uniform1f(uTime, (now - t0) / 1000);
      gl.uniform1f(uScrl, smooth);
      gl.uniform1f(uScn,  si);
      gl.uniform1f(uBld,  bl);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
    };

    requestAnimationFrame(frame);

    /* ── Cleanup on Astro navigation ── */
    document.addEventListener('astro:before-preparation', () => {
      disposed = true;
      window.removeEventListener('resize', resize);
    }, { once: true });
  })();
</script>
