---
/**
 * TextSplitter — Splits text into individual characters that animate in
 * with stagger on scroll. Ported from ReactBits SplitText pattern.
 *
 * Usage:
 *   <TextSplitter text="Hello world" tag="h2" class="my-heading" />
 *   <TextSplitter text="Subtitle here" tag="p" delay={200} />
 */
interface Props {
  text: string;
  tag?: string;
  class?: string;
  delay?: number;        // ms before animation starts
  stagger?: number;      // ms between each character
  animation?: 'rise' | 'blur' | 'wave';
}

const {
  text,
  tag = 'span',
  class: className = '',
  delay = 0,
  stagger = 25,
  animation = 'rise',
} = Astro.props;

const Tag = tag;
const chars = text.split('');
---

<Tag
  class={`text-splitter text-splitter--${animation} ${className}`}
  data-text-split
  data-split-delay={delay}
  data-split-stagger={stagger}
  aria-label={text}
>
  {chars.map((char, i) => (
    <span
      class={`ts-char ${char === ' ' ? 'ts-space' : ''}`}
      style={`--i: ${i};`}
      aria-hidden="true"
    >{char === ' ' ? '\u00A0' : char}</span>
  ))}
</Tag>

<style>
  .text-splitter {
    display: inline;
  }

  .ts-char {
    display: inline-block;
    will-change: transform, opacity;
  }

  .ts-space {
    width: 0.3em;
  }

  /* === Rise: characters slide up from below === */
  .js .text-splitter--rise .ts-char {
    opacity: 0;
    transform: translateY(0.6em) rotateX(45deg);
    transition: opacity 0.5s var(--ease-out-expo),
                transform 0.5s var(--ease-out-expo);
  }

  .js .text-splitter--rise.is-split-visible .ts-char {
    opacity: 1;
    transform: translateY(0) rotateX(0);
  }

  /* === Blur: characters go from blurred/invisible to sharp === */
  .js .text-splitter--blur .ts-char {
    opacity: 0;
    filter: blur(8px);
    transform: translateY(4px);
    transition: opacity 0.6s var(--ease-out-expo),
                filter 0.5s var(--ease-out-expo),
                transform 0.5s var(--ease-out-expo);
  }

  .js .text-splitter--blur.is-split-visible .ts-char {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  /* === Wave: characters pop in with spring overshoot === */
  .js .text-splitter--wave .ts-char {
    opacity: 0;
    transform: translateY(0.4em) scale(0.5);
    transition: opacity 0.4s ease,
                transform 0.6s var(--ease-spring);
  }

  .js .text-splitter--wave.is-split-visible .ts-char {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .js .text-splitter .ts-char {
      opacity: 1 !important;
      transform: none !important;
      filter: none !important;
      transition: none !important;
    }
  }
</style>

<script>
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const splitters = document.querySelectorAll<HTMLElement>('[data-text-split]');
    if (!splitters.length) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const baseDelay = parseInt(el.dataset.splitDelay || '0', 10);
        const stagger = parseInt(el.dataset.splitStagger || '25', 10);

        const chars = el.querySelectorAll<HTMLElement>('.ts-char');
        chars.forEach((char, i) => {
          char.style.transitionDelay = `${baseDelay + i * stagger}ms`;
        });

        el.classList.add('is-split-visible');
        observer.unobserve(el);
      });
    }, { threshold: 0.3 });

    splitters.forEach((s) => observer.observe(s));
  })();
</script>
