---
import ParticleScene from './ParticleScene.astro';
import ParticleNetwork from './ParticleNetwork.astro';
import Aurora from './Aurora.astro';

const proofPoints = [
  {
    label: 'Promesa',
    value: 'Decidir con anticipación antes de quedar reactivos',
  },
  {
    label: 'Formato',
    value: 'Señales, simulación y criterio operativo',
  },
  {
    label: 'Cadencia',
    value: '4-5 semanas por caso completo',
  },
];

const lexicon = [
  'señales.',
  'actores.',
  'fricciones.',
  'escenarios.',
];

const strips = [
  'señales prioritarias',
  'mapeo de actores',
  'simulación con evidencia',
  'decisión bajo incertidumbre',
  'prospectiva estratégica',
  'criterio para decidir',
];

const disclosurePills = [
  'Signal scanning',
  'Actor mapping',
  'Scenario logic',
  'Trazabilidad',
];

const stripLoop = [...strips, ...strips, ...strips];
---

<section class="section-shell hero-shell" id="hero">
  <!-- Aurora gradient atmosphere -->
  <Aurora
    class="hero-aurora"
    colorA="rgba(72, 101, 255, 0.14)"
    colorB="rgba(255, 92, 56, 0.08)"
    colorC="rgba(122, 104, 214, 0.08)"
    speed={0.8}
  />

  <!-- Subtle particle network for depth -->
  <ParticleNetwork
    class="hero-particles"
    color="#8899aa"
    count={35}
    opacity={0.32}
    linkDistance={120}
  />

  <!-- Coral torus — top right atmospheric accent -->
  <div class="hero-3d-wrap" data-parallax="0.08" aria-hidden="true">
    <img src="/3d/torus-coral.webp" alt="" class="hero-3d" loading="eager" width="340" height="280" />
  </div>

  <div class="container hero-stack">
    <div class="hero-copy" data-hero-anim>
      <p class="section-kicker hero-kicker">Consultoría de prospectiva estratégica</p>

      <h1 class="hero-title-stage" aria-label="Decidir antes de reaccionar.">
        <span class="hero-line hero-line--1">
          <span class="hero-word" data-word>Decidir</span>
        </span>
        <span class="hero-line hero-line--2">
          <span class="hero-word hero-word--accent" data-word><em>antes</em></span>
          <span class="hero-word hero-word--mono" data-word>de</span>
        </span>
        <span class="hero-line hero-line--3">
          <span class="hero-word hero-word--strike" data-word data-strike>reaccionar.</span>
        </span>
      </h1>

      <p class="hero-body" data-hero-body>
        Simulamos escenarios para que tu equipo decida
        con <em>información,</em> no con urgencia.
      </p>

      <div class="button-row hero-actions" data-hero-actions>
        <a class="button button-primary" href="https://daseinforesight.zohobookings.com/#/4731633000000049054" target="_blank" rel="noreferrer">Agenda una conversación</a>
        <a class="button button-secondary" href="#metodo">Ver el método</a>
      </div>
    </div>

  </div>

  <div class="container hero-strip-wrap" data-reveal>
    <div class="marquee hero-strip" aria-hidden="true">
      <div class="marquee-track">
        {stripLoop.map((item) => (
          <span class="marquee-item">{item}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<div class="hero-pin-wrapper" data-particle-host>
  <section class="hero-disclosure-shell section-dark" data-pin-target>
    <ParticleScene />
    <div class="scanlines hero-disclosure-scanlines" aria-hidden="true"></div>
    <div class="noise-overlay hero-disclosure-noise" aria-hidden="true"></div>
    <div class="vignette-overlay hero-disclosure-vignette" aria-hidden="true"></div>

    <div class="container hero-disclosure-inner">
      <div class="hero-disclosure-copy" data-reveal>
        <span class="tag hero-disclosure-tag">Lectura de sistema</span>

        <h2 class="hero-disclosure-title">
          Leemos
        </h2>
      </div>

      <div class="hero-carousel" data-lexicon-carousel>
        <div class="hero-carousel-track">
          {lexicon.map((item, index) => (
            <span
              class="hero-carousel-word"
              data-word-index={index}
              style={`--i: ${index};`}
            >{item}</span>
          ))}
        </div>
      </div>

      <p class="hero-disclosure-note" data-reveal>
        Antes de simular, leemos el sistema completo: quién juega, qué presiona, qué puede cambiar.
      </p>
    </div>
  </section>
</div>

<style>
  .hero-shell {
    padding-top: var(--hero-space);
    padding-bottom: 1.5rem;
    position: relative;
    overflow: visible;
  }

  .hero-aurora {
    mask-image: radial-gradient(ellipse 80% 70% at 50% 30%, black 0%, transparent 100%);
    opacity: 0.85;
  }

  .hero-particles {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.5;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 0%, transparent 100%);
  }

  .hero-stack {
    display: grid;
    gap: 2.4rem;
    justify-items: center;
    text-align: center;
  }

  .hero-copy {
    display: grid;
    gap: 2rem;
    justify-items: center;
    max-width: 68rem;
  }

  /* === Animated title stage === */
  .hero-title-stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1em;
    font-family: var(--font-display);
    font-size: clamp(4rem, 2.5rem + 6vw, 9rem);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.04em;
    text-align: center;
  }

  .hero-line {
    display: flex;
    align-items: baseline;
    gap: 0.25em;
    overflow: hidden;
  }

  .hero-word {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
    transition: none;
  }

  .hero-word.is-visible {
    transform: translateY(0);
    opacity: 1;
  }

  .hero-word--accent em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
    color: var(--signal-red);
  }

  .hero-word--mono {
    font-family: var(--font-mono);
    font-size: 0.55em;
    letter-spacing: 0.04em;
    font-weight: 400;
    color: var(--ink-faint);
    align-self: center;
  }

  .hero-word--strike {
    position: relative;
  }

  .hero-word--strike::after {
    content: '';
    position: absolute;
    left: -4%;
    right: -4%;
    top: 52%;
    height: 3px;
    background: var(--signal-red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.6s var(--ease-out-expo);
  }

  .hero-word--strike.is-struck::after {
    transform: scaleX(1);
  }

  .hero-word--strike.is-struck {
    color: var(--ink-faint);
    transition: color 0.4s ease 0.3s;
  }

  .hero-body {
    max-width: 36rem;
    color: var(--ink-soft);
    font-size: clamp(1.05rem, 0.98rem + 0.4vw, 1.22rem);
    text-align: center;
    opacity: 0;
    transform: translateY(16px);
  }

  .hero-body em {
    font-family: var(--font-editorial);
    font-style: italic;
    color: var(--signal-red);
  }

  .hero-body.is-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s var(--ease-out-expo), transform 0.7s var(--ease-out-expo);
  }

  .hero-actions {
    opacity: 0;
    transform: translateY(12px);
  }

  .hero-actions.is-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
  }

  .hero-kicker {
    opacity: 0;
  }

  .hero-kicker.is-visible {
    opacity: 1;
    transition: opacity 0.5s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-word,
    .hero-body,
    .hero-actions,
    .hero-kicker {
      opacity: 1 !important;
      transform: none !important;
    }
    .hero-word--strike::after {
      transform: scaleX(1) !important;
    }
    .hero-word--strike {
      color: var(--ink-faint) !important;
    }
  }

  .hero-proof-grid {
    display: grid;
    gap: 0.9rem;
    width: 100%;
    max-width: 54rem;
  }

  .hero-proof {
    padding: 1rem 1.15rem 1.15rem;
  }

  .hero-proof-label {
    display: inline-block;
    margin-bottom: 0.35rem;
    color: var(--ink-faint);
  }

  .hero-proof p {
    color: var(--ink);
    line-height: 1.42;
  }

  .hero-strip-wrap {
    margin-top: 1.1rem;
    isolation: isolate;
    transform: translateZ(0);
    contain: layout style;
  }

  .hero-strip {
    padding-block: 0.5rem;
  }

  /* === Sticky pin wrapper === */
  .hero-pin-wrapper {
    /* Height = 100vh visible + N words * scroll distance each */
    height: calc(100vh + var(--lexicon-scroll-height, 300vh));
    position: relative;
  }

  .hero-disclosure-shell {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    isolation: isolate;
    display: grid;
    place-items: center;
  }

  .hero-disclosure-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 14% 22%, rgba(72, 101, 255, 0.18), transparent 24%),
      radial-gradient(circle at 86% 18%, rgba(255, 184, 115, 0.08), transparent 20%);
    z-index: 0;
  }

  .hero-disclosure-scanlines,
  .hero-disclosure-noise,
  .hero-disclosure-vignette {
    z-index: 1;
  }

  .hero-disclosure-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0;
    min-height: 60vh;
  }

  .hero-disclosure-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 1rem;
  }

  .hero-disclosure-tag {
    color: rgba(243, 245, 248, 0.4);
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.06);
  }

  .hero-disclosure-tag::before {
    content: '◇';
    color: var(--signal-blue);
    opacity: 0.5;
  }

  .hero-disclosure-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1rem + 2vw, 2.8rem);
    line-height: 1;
    letter-spacing: -0.025em;
    font-weight: 500;
    color: rgba(243, 245, 248, 0.5);
  }

  /* === Carousel — vertical roulette with depth === */
  .hero-carousel {
    --reel-height: clamp(22rem, 18rem + 12vw, 34rem);
    position: relative;
    height: var(--reel-height);
    overflow: hidden;
    width: 100%;
    display: flex;
    justify-content: center;
    /* Soft fade at top and bottom edges */
    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0,0,0,0.3) 15%,
      black 35%,
      black 65%,
      rgba(0,0,0,0.3) 85%,
      transparent 100%
    );
  }

  .hero-carousel-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-carousel-word {
    --word-h: clamp(4.2rem, 3rem + 3vw, 5.8rem);
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 2rem + 4.5vw, 7rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
    font-weight: 900;
    white-space: nowrap;
    height: var(--word-h);
    display: flex;
    align-items: center;

    /* Default: deeply faded */
    color: rgba(243, 245, 248, 0.05);
    opacity: 0.2;
    filter: blur(4px);
    transform: scale(0.88);
    transition:
      color 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Active word: fully lit, sharp, centered */
  .hero-carousel-word.is-active {
    color: var(--signal-blue, #4865ff);
    opacity: 1;
    filter: blur(0px);
    transform: scale(1);
  }

  /* 1 step away: visible ghost */
  .hero-carousel-word.is-near-1 {
    color: rgba(72, 101, 255, 0.18);
    opacity: 0.55;
    filter: blur(1.5px);
    transform: scale(0.94);
  }

  /* 2 steps away: fading out */
  .hero-carousel-word.is-near-2 {
    color: rgba(243, 245, 248, 0.08);
    opacity: 0.3;
    filter: blur(3px);
    transform: scale(0.9);
  }

  .hero-disclosure-note {
    margin-top: 2rem;
    max-width: 32rem;
    text-align: center;
    color: rgba(243, 245, 248, 0.36);
    font-size: var(--text-sm);
  }

  @media (min-width: 980px) {
    .hero-proof-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .hero-disclosure-grid {
      grid-template-columns: minmax(0, 0.78fr) minmax(360px, 1.04fr);
    }
  }

  /* ── 3D floating accent ── */
  .hero-3d-wrap {
    position: absolute;
    pointer-events: none;
    user-select: none;
    z-index: 2;
    will-change: transform;
    width: clamp(200px, 24vw, 340px);
    top: 2%;
    right: -2%;
    transform: translateY(var(--plx-y, 0));
  }

  .hero-3d {
    width: 100%;
    height: auto;
    display: block;
    opacity: 0.45;
    filter: saturate(1.3);
    animation: hero-float 14s ease-in-out infinite;
  }

  @keyframes hero-float {
    0%, 100% { transform: rotate(-12deg) translateY(0); }
    50% { transform: rotate(-10deg) translateY(-18px); }
  }

  @media (max-width: 767px) { .hero-3d-wrap { display: none; } }
  @media (prefers-reduced-motion: reduce) {
    .hero-3d { animation: none !important; }
    .hero-3d-wrap { transform: none !important; }
  }

  /* ── Mobile editorial layout ── */
  @media (max-width: 860px) {
    .hero-shell {
      padding-top: clamp(4rem, 3rem + 5vw, 6rem);
    }

    .hero-particles {
      display: none;
    }

    .hero-3d-wrap {
      display: none;
    }

    .hero-title-stage {
      font-size: clamp(2.8rem, 2rem + 4vw, 4rem);
    }

    .hero-kicker {
      justify-content: center;
    }

    .hero-stack {
      text-align: center;
    }

    .hero-copy {
      justify-items: center;
      max-width: 100%;
    }

    .hero-body {
      max-width: 90%;
      text-align: center;
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
      max-width: 90%;
    }

    .hero-actions .button {
      width: 100%;
      text-align: center;
    }

    .hero-strip .marquee-item {
      font-size: 0.65rem;
      padding: 0.55rem 0.75rem;
    }

    .hero-strip-wrap {
      margin-top: 0.6rem;
    }

    /* Disclosure: keep scroll-driven but with smaller sizing */
    .hero-carousel {
      --reel-height: clamp(14rem, 12rem + 8vw, 20rem);
    }

    .hero-carousel-word {
      font-size: clamp(2.4rem, 1.5rem + 3.5vw, 4rem);
      --word-h: clamp(3rem, 2.5rem + 2vw, 4rem);
    }

    .hero-disclosure-title {
      font-size: clamp(1.4rem, 1rem + 1.5vw, 2rem);
    }

    .hero-disclosure-note {
      margin-top: 1.2rem;
      max-width: 90%;
    }
  }

</style>

<script>
  /* === Hero text entrance animation === */
  (() => {
    const stage = document.querySelector('[data-hero-anim]');
    if (!stage || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const words = stage.querySelectorAll('[data-word]');
    const body = stage.querySelector('[data-hero-body]');
    const actions = stage.querySelector('[data-hero-actions]');
    const kicker = stage.querySelector('.hero-kicker');
    const strikeWord = stage.querySelector('[data-strike]');

    // Spring-like easing via JS for word reveals
    const springEase = 'cubic-bezier(0.34, 1.56, 0.64, 1)';
    let delay = 300; // initial delay after page load

    // Kicker fades in first
    setTimeout(() => {
      kicker?.classList.add('is-visible');
    }, delay);
    delay += 400;

    // Each word slides up from below with staggered timing
    words.forEach((word, i) => {
      const el = word as HTMLElement;
      const wordDelay = delay + i * 220;
      const dur = 700 + i * 40; // slightly slower for later words

      setTimeout(() => {
        el.style.transition = `transform ${dur}ms ${springEase}, opacity ${dur * 0.6}ms ease`;
        el.classList.add('is-visible');
      }, wordDelay);
    });

    // After all words, strike through "reaccionar"
    const strikeDelay = delay + words.length * 220 + 600;
    setTimeout(() => {
      strikeWord?.classList.add('is-struck');
    }, strikeDelay);

    // Body text appears after the strike
    setTimeout(() => {
      body?.classList.add('is-visible');
    }, strikeDelay + 500);

    // CTAs last
    setTimeout(() => {
      actions?.classList.add('is-visible');
    }, strikeDelay + 800);
  })();

  /* === Lexicon carousel (scroll-driven) === */
  const wrapper = document.querySelector('.hero-pin-wrapper');
  const track = document.querySelector('.hero-carousel-track') as HTMLElement | null;
  const words = document.querySelectorAll('.hero-carousel-word');

  if (wrapper && track && words.length) {
    const wordCount = words.length;
    const wordEl = words[0] as HTMLElement;
    const carousel = document.querySelector('.hero-carousel') as HTMLElement;

    // Shorter scroll distance on mobile
    const isMobile = window.innerWidth < 860;
    const scrollMultiplier = isMobile ? 35 : 55;
    wrapper.style.setProperty('--lexicon-scroll-height', `${wordCount * scrollMultiplier}vh`);

    let prevActive = -1;

    const update = () => {
      const rect = wrapper.getBoundingClientRect();
      const scrolled = -rect.top;
      const totalScroll = (wrapper as HTMLElement).offsetHeight - window.innerHeight;

      if (scrolled < 0 || totalScroll <= 0) return;

      const progress = Math.min(scrolled / totalScroll, 1);
      const activeIndex = Math.min(Math.floor(progress * wordCount), wordCount - 1);

      // Move track so active word is centered in the reel
      const wordHeight = wordEl.offsetHeight;
      const reelCenter = carousel.offsetHeight / 2;
      const targetY = reelCenter - (activeIndex * wordHeight) - (wordHeight / 2);
      track.style.transform = `translateY(${targetY}px)`;

      // Skip class work if nothing changed
      if (activeIndex === prevActive) return;
      prevActive = activeIndex;

      // Roulette depth: highlight active, fade by distance
      words.forEach((w, i) => {
        w.classList.remove('is-active', 'is-near-1', 'is-near-2');
        const dist = Math.abs(i - activeIndex);
        if (dist === 0) {
          w.classList.add('is-active');
        } else if (dist === 1) {
          w.classList.add('is-near-1');
        } else if (dist === 2) {
          w.classList.add('is-near-2');
        }
      });
    };

    let ticking = false;
    const onCarouselScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
        ticking = true;
      }
    };
    window.addEventListener('scroll', onCarouselScroll, { passive: true });

    update();

    // Cleanup on Astro navigation
    document.addEventListener('astro:before-preparation', () => {
      window.removeEventListener('scroll', onCarouselScroll);
    }, { once: true });
  }
</script>
