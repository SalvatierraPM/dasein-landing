---
interface Props {
  variant?: 'light' | 'dark';
  size?: 'nav' | 'footer';
  caption?: string;
  alt?: string;
}

const {
  variant = 'light',
  size = 'nav',
  caption,
  alt = 'Dasein Foresight',
} = Astro.props;
---

<div class:list={['brand-logo', `brand-logo--${variant}`, `brand-logo--${size}`]} aria-label={alt}>
  <div class="brand-logo__lockup">
    <span class="brand-logo__mark-wrap" aria-hidden="true">
      <img
        class="brand-logo__mark"
        src="/brand/dasein-mark-tight.png"
        alt=""
        loading="eager"
        decoding="async"
      />
    </span>

    <span class="brand-logo__type">
      <span class="brand-logo__name">Dasein</span>
      <span class="brand-logo__sub">Foresight</span>
    </span>
  </div>

  {caption && <span class="brand-logo__caption">{caption}</span>}
</div>

<style>
  .brand-logo {
    display: grid;
    gap: 0.32rem;
    width: fit-content;
  }

  .brand-logo--nav {
    width: clamp(11.5rem, 17vw, 15rem);
  }

  .brand-logo--footer {
    width: clamp(11rem, 14vw, 13.25rem);
  }

  .brand-logo__lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.62rem;
    flex-wrap: nowrap;
  }

  .brand-logo__mark-wrap {
    width: clamp(2.3rem, 3vw, 2.95rem);
    aspect-ratio: 27 / 28;
    flex: 0 0 auto;
    transform: translateY(0.08rem);
    filter: drop-shadow(0 10px 18px rgba(129, 112, 84, 0.12));
  }

  .brand-logo__mark {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: saturate(0.96) contrast(1.02);
    -webkit-mask-image: radial-gradient(ellipse at 50% 52%, rgba(0, 0, 0, 1) 52%, rgba(0, 0, 0, 0.94) 72%, transparent 94%);
    mask-image: radial-gradient(ellipse at 50% 52%, rgba(0, 0, 0, 1) 52%, rgba(0, 0, 0, 0.94) 72%, transparent 94%);
  }

  .brand-logo--footer .brand-logo__mark-wrap {
    width: clamp(2.55rem, 3.4vw, 3.15rem);
    filter: drop-shadow(0 12px 20px rgba(255, 233, 197, 0.08));
  }

  .brand-logo__type {
    display: grid;
    gap: 0.12rem;
  }

  .brand-logo__name {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(1.26rem, 1.46vw, 1.62rem);
    font-weight: 300;
    line-height: 0.9;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    white-space: nowrap;
  }

  .brand-logo__sub {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 0.42rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }

  .brand-logo__caption {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    line-height: 1.2;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
    white-space: nowrap;
  }

  .brand-logo--dark .brand-logo__caption {
    color: rgba(243, 245, 248, 0.44);
  }

  .brand-logo--dark .brand-logo__name {
    color: var(--slate-white);
  }

  .brand-logo--dark .brand-logo__sub {
    color: rgba(243, 245, 248, 0.76);
  }

  .brand-logo--dark .brand-logo__mark {
    filter: brightness(1.02) saturate(0.92) contrast(1.03);
  }

  @media (max-width: 840px) {
    .brand-logo--nav {
      width: clamp(10.5rem, 58vw, 13rem);
    }

    .brand-logo__mark-wrap {
      width: clamp(2.15rem, 9.5vw, 2.65rem);
    }

    .brand-logo__name {
      font-size: clamp(1.12rem, 4.6vw, 1.4rem);
    }

    .brand-logo__sub {
      font-size: 0.38rem;
      letter-spacing: 0.32em;
    }

    .brand-logo__caption {
      font-size: 0.54rem;
      white-space: normal;
    }
  }
</style>
