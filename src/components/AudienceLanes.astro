---
const audienceCards = [
  {
    label: 'Pilotos',
    num: '01',
    title: 'Organizaciones que quieran probar el enfoque con un caso real.',
    body: 'Un caso completo: lectura del sistema, simulación multiagente y cierre en plan a 90 días con workshop ejecutivo. El formato ideal para probar el enfoque antes de comprometer un proyecto largo.',
    details: ['Decisiones con componente regulatorio o político', 'Transformaciones donde la lectura del entorno es crítica', 'Casos donde el costo de improvisar supera el costo de modelar'],
  },
  {
    label: 'Partners',
    num: '02',
    title: 'Firmas que implementan mejor cuando el mapa ya existe.',
    body: 'Consultoras de cambio, IA, producto o transformación digital que quieran recibir un mapa estratégico listo para ejecutar. Dasein modela, el partner despliega.',
  },
  {
    label: 'Equipo',
    num: '03',
    title: 'Perfiles que quieran construir esto juntos.',
    body: 'Prospectiva, research, computational social science, product design y AI engineering. Buscamos profundidad metodológica y ganas de operar en la intersección.',
  },
  {
    label: 'Investigadores',
    num: '04',
    title: 'Académicos que necesiten una plataforma de simulación auditable.',
    body: 'Universidades, laboratorios y programas que exploran escenarios, política pública o transformación institucional con acceso a SignalTwin.',
  },
];

const marqueeItems = ['Pilotos', 'Partners', 'Equipo', 'Investigadores', 'Alianzas', 'Colaboradores'];
---

<section class="audience-section" id="audiencias">
  <!-- White torus — background atmospheric -->
  <div class="audience-3d-wrap" data-parallax="0.06" aria-hidden="true">
    <img src="/3d/torus-white.webp" alt="" class="audience-3d" loading="lazy" decoding="async" width="260" height="220" />
  </div>

  <!-- Marquee strip -->
  <div class="audience-marquee" aria-hidden="true">
    <div class="audience-marquee-track">
      {[...marqueeItems, ...marqueeItems, ...marqueeItems].map((item) => (
        <span class="audience-marquee-item">{item}</span>
      ))}
    </div>
  </div>

  <div class="container">
    <!-- Editorial intro: kicker above, headline flush-left -->
    <div class="audience-intro" data-reveal>
      <span class="section-kicker">06 / Para quién</span>
      <h2 class="audience-headline">
        Estamos construyendo.<br />
        <em>Buscamos a quienes faltan.</em>
      </h2>
      <p class="audience-lead">
        Cuatro formas de trabajar con nosotros, según dónde estés y qué necesites.
      </p>
    </div>

    <!-- Lanes -->
    <div class="audience-lanes" data-reveal-stagger>
      {audienceCards.map((card, i) => (
        <article class="audience-lane" data-reveal data-cursor-grow>
          <div class="audience-lane-left">
            <span class="audience-num">{card.num}</span>
            <span class="audience-label">{card.label}</span>
          </div>
          <div class="audience-lane-right">
            <h3 class="audience-lane-title">{card.title}</h3>
            <div class="audience-lane-body">
              <p>{card.body}</p>
              {card.details && (
                <ul class="audience-details">
                  {card.details.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}
            </div>
            <span class="audience-lane-toggle" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path class="toggle-h" d="M0 7h14" stroke="currentColor" stroke-width="1.5"/>
                <path class="toggle-v" d="M7 0v14" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* ─── Section ─── */
  .audience-section {
    padding-block: var(--space-section);
    overflow: hidden;
    position: relative;
  }

  /* ─── Marquee ─── */
  .audience-marquee {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding-block: clamp(0.6rem, 1vw, 0.9rem);
    margin-bottom: clamp(4rem, 5vw, 7rem);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
  }

  .audience-marquee-track {
    display: flex;
    gap: clamp(2rem, 4vw, 4rem);
    white-space: nowrap;
    will-change: transform;
    animation: marquee-scroll 28s linear infinite;
  }

  @keyframes marquee-scroll {
    to {
      transform: translateX(-33.333%);
    }
  }

  .audience-marquee-item {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: clamp(2rem, 4vw, 4rem);
  }

  .audience-marquee-item::after {
    content: '※';
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--signal-red);
    opacity: 0.4;
    flex-shrink: 0;
  }

  /* ─── Intro ─── */
  .audience-intro {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem clamp(3rem, 5vw, 6rem);
    align-items: end;
    margin-bottom: clamp(4rem, 5vw, 7rem);
  }

  .audience-intro .section-kicker {
    grid-column: 1 / -1;
  }

  .audience-headline {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    font-weight: 700;
  }

  .audience-headline em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .audience-lead {
    color: var(--ink-soft);
    font-size: clamp(1.05rem, 1rem + 0.3vw, 1.2rem);
    line-height: var(--leading-body);
    max-width: 28rem;
    align-self: end;
    padding-bottom: 0.3rem;
  }

  /* ─── Lanes container ─── */
  .audience-lanes {
    display: grid;
    gap: 0;
  }

  /* ─── Single lane ─── */
  .audience-lane {
    display: grid;
    grid-template-columns: clamp(7rem, 10vw, 11rem) 1fr;
    gap: clamp(2rem, 3vw, 4rem);
    align-items: start;
    padding-block: clamp(2.5rem, 3.5vw, 4.5rem);
    border-top: 1px solid var(--line);
    cursor: pointer;
    position: relative;
  }

  .audience-lane:last-child {
    border-bottom: 1px solid var(--line);
  }

  /* ─── Left column: number + label ─── */
  .audience-lane-left {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.2rem;
  }

  .audience-num {
    font-family: var(--font-mono);
    font-size: clamp(1.4rem, 1rem + 1vw, 2rem);
    font-weight: 500;
    letter-spacing: var(--tracking-mono);
    line-height: 1;
    color: var(--signal-red);
  }

  .audience-label {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    transition: color var(--dur-normal) ease;
  }

  .audience-lane:hover .audience-label {
    color: var(--ink-soft);
  }

  /* ─── Right column: title + body ─── */
  .audience-lane-right {
    position: relative;
  }

  .audience-lane-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.2rem + 1.5vw, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    font-weight: 500;
    max-width: 26ch;
    transition: color var(--dur-normal) var(--ease-out-expo);
    padding-right: 3rem;
  }

  .audience-lane:hover .audience-lane-title,
  .audience-lane.is-open .audience-lane-title {
    color: oklch(45% 0.08 40);
  }

  /* ─── Toggle icon ─── */
  .audience-lane-toggle {
    position: absolute;
    top: 0.5rem;
    right: 0;
    color: var(--ink-faint);
    transition: color var(--dur-normal) ease;
  }

  .audience-lane-toggle .toggle-v {
    transition: transform var(--dur-slow) var(--ease-out-expo);
    transform-origin: center;
  }

  .audience-lane.is-open .audience-lane-toggle .toggle-v {
    transform: scaleY(0);
  }

  .audience-lane:hover .audience-lane-toggle {
    color: oklch(45% 0.08 40);
  }

  /* ─── Expandable body ─── */
  .audience-lane-body {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows var(--dur-slow) var(--ease-out-expo),
      opacity var(--dur-normal) ease;
    margin-top: 0;
  }

  .audience-lane-body > * {
    overflow: hidden;
  }

  .audience-lane.is-open .audience-lane-body {
    grid-template-rows: 1fr;
    opacity: 1;
    margin-top: clamp(1rem, 1.5vw, 1.6rem);
  }

  .audience-lane-body p {
    color: var(--ink-soft);
    max-width: 42rem;
    line-height: var(--leading-body);
    padding-bottom: 0.5rem;
  }

  /* ─── Details list ─── */
  .audience-details {
    list-style: none;
    display: grid;
    gap: 0.45rem;
    padding: 0;
    margin-top: 0.8rem;
  }

  .audience-details li {
    font-family: var(--font-mono);
    color: var(--ink-faint);
    font-size: 0.76rem;
    letter-spacing: 0.02em;
    padding-left: 1.2rem;
    position: relative;
  }

  .audience-details li::before {
    content: '※';
    position: absolute;
    left: 0;
    top: 0;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--signal-blue);
    opacity: 0.6;
  }

  /* ─── Lane stagger entrance from left ─── */
  [data-reveal-stagger] > .audience-lane {
    opacity: 0;
    transform: translateX(-12px);
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
  }

  [data-reveal-stagger].revealed > .audience-lane:nth-child(1) { opacity: 1; transform: translateX(0); transition-delay: 0s; }
  [data-reveal-stagger].revealed > .audience-lane:nth-child(2) { opacity: 1; transform: translateX(0); transition-delay: 0.08s; }
  [data-reveal-stagger].revealed > .audience-lane:nth-child(3) { opacity: 1; transform: translateX(0); transition-delay: 0.16s; }
  [data-reveal-stagger].revealed > .audience-lane:nth-child(4) { opacity: 1; transform: translateX(0); transition-delay: 0.24s; }

  /* ─── Toggle rotation on lane hover ─── */
  .audience-lane:hover .audience-lane-toggle {
    transform: rotate(12deg);
    transition: transform 0.3s var(--ease-spring);
  }

  /* ─── Responsive ─── */
  @media (max-width: 720px) {
    .audience-intro {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .audience-lane {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .audience-lane-left {
      flex-direction: row;
      align-items: baseline;
      gap: 1rem;
    }

    .audience-num {
      font-size: clamp(1.1rem, 1rem + 0.5vw, 1.4rem);
    }

    .audience-lane-title {
      padding-right: 2.5rem;
    }

    .audience-lane-toggle {
      top: 0.25rem;
    }
  }

  /* ─── Mobile editorial ─── */
  @media (max-width: 860px) {
    .audience-intro {
      grid-template-columns: 1fr;
      gap: 1.2rem;
      text-align: center;
    }

    .audience-intro .section-kicker {
      justify-content: center;
    }

    .audience-headline {
      text-align: center;
    }

    .audience-lead {
      text-align: center;
      max-width: 100%;
      margin-inline: auto;
    }

    .audience-marquee-item {
      font-size: 0.62rem;
    }

    .audience-marquee {
      margin-bottom: clamp(2.5rem, 4vw, 4rem);
    }

    .audience-lane {
      grid-template-columns: 1fr;
      gap: 0.8rem;
      padding-block: clamp(2rem, 3vw, 3rem);
    }

    .audience-lane-left {
      flex-direction: row;
      align-items: baseline;
      gap: 0.8rem;
    }

    .audience-num {
      font-size: clamp(1.2rem, 1rem + 0.5vw, 1.5rem);
    }

    /* Always open on mobile — no accordion needed */
    .audience-lane-body {
      grid-template-rows: 1fr;
      opacity: 1;
      margin-top: clamp(0.8rem, 1vw, 1.2rem);
    }

    .audience-lane-toggle {
      display: none;
    }

    .audience-lane-title {
      padding-right: 0;
      font-size: clamp(1.5rem, 1.1rem + 1.2vw, 2.2rem);
    }

    .audience-3d-wrap {
      display: none;
    }
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .audience-marquee-track {
      animation: none;
    }

    .audience-lane-body {
      grid-template-rows: 1fr;
      opacity: 1;
      margin-top: clamp(1rem, 1.5vw, 1.6rem);
    }

    .audience-lane.is-open .audience-lane-toggle .toggle-v {
      transform: none;
    }

    [data-reveal-stagger] > .audience-lane {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .audience-lane:hover .audience-lane-toggle {
      transform: none;
      transition: none;
    }
  }

  /* ── 3D floating accent ── */
  .audience-3d-wrap {
    position: absolute;
    pointer-events: none;
    user-select: none;
    z-index: 1;
    will-change: transform;
    width: clamp(180px, 20vw, 300px);
    top: 5%;
    right: -3%;
    transform: translateY(var(--plx-y, 0));
  }

  .audience-3d {
    width: 100%;
    height: auto;
    display: block;
    opacity: 0.32;
    filter: brightness(0.82) saturate(0.7);
    animation: aud-float 12s ease-in-out infinite;
    animation-delay: -4s;
  }

  @keyframes aud-float {
    0%, 100% { transform: rotate(15deg) translateY(0); }
    50% { transform: rotate(18deg) translateY(-14px); }
  }

  @media (max-width: 767px) { .audience-3d-wrap { display: none; } }
  @media (prefers-reduced-motion: reduce) {
    .audience-3d { animation: none !important; }
    .audience-3d-wrap { transform: none !important; }
  }
</style>

<script>
  const lanes = document.querySelectorAll('.audience-lane');
  const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

  lanes.forEach((lane) => {
    if (isTouchDevice) {
      lane.addEventListener('click', () => {
        const wasOpen = lane.classList.contains('is-open');
        lanes.forEach((l) => l.classList.remove('is-open'));
        if (!wasOpen) lane.classList.add('is-open');
      });
    } else {
      lane.addEventListener('mouseenter', () => {
        lanes.forEach((l) => l.classList.remove('is-open'));
        lane.classList.add('is-open');
      });
      lane.addEventListener('mouseleave', () => {
        lane.classList.remove('is-open');
      });
    }
  });
</script>
