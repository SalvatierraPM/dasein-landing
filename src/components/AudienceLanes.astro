---
const audienceCards = [
  {
    label: 'Pilots',
    title: 'Para organizaciones con decisiones donde una mala lectura del entorno sale cara.',
    body: 'Dasein entra cuando la decision tiene componente politico, regulatorio, tecnologico o reputacional, y el costo de improvisar es mas alto que el costo de leer bien el sistema.',
    bullets: ['Transformaciones con riesgo institucional', 'IA aplicada en operaciones sensibles', 'Lanzamientos que requieren criterio antes que velocidad'],
    lead: true,
  },
  {
    label: 'Partners',
    title: 'Equipos que implementan mejor cuando el mapa estrategico ya existe.',
    body: 'Firmas de cambio, IA, producto o transformacion que pueden tomar el trabajo despues del modelamiento, no antes.',
  },
  {
    label: 'Collaborators',
    title: 'Perfiles que suman profundidad metodologica.',
    body: 'Research, foresight, product y computational social science para elevar la lectura de sistemas complejos.',
  },
  {
    label: 'Innovation labs',
    title: 'Espacios que necesitan una metodologia auditable.',
    body: 'Universidades, laboratorios y programas que exploran escenarios, politica publica o transformacion institucional.',
  },
];
---

<section class="audience-section" id="audiencias">
  <div class="container">
    <div class="section-head" data-reveal>
      <div class="section-index">01 / Para quien</div>
      <div>
        <h2 class="section-title">Una landing para pilotos serios, no para curiosidad de vitrina.</h2>
        <p class="section-copy">
          La entrada principal esta pensada para equipos que necesitan ordenar decisiones complejas
          antes de ejecutarlas. Partners y colaboradores existen, pero no compiten por el relato.
        </p>
      </div>
    </div>

    <div class="audience-grid">
      {audienceCards.map((card) => (
        <article class={`audience-card panel ${card.lead ? 'audience-card--lead' : ''}`} data-reveal>
          <small>{card.label}</small>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
          {card.bullets && (
            <ul>
              {card.bullets.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .audience-section {
    padding-top: 0;
  }

  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .audience-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: clamp(1.4rem, 2vw, 1.8rem);
  }

  .audience-card small {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .audience-card h3 {
    font-size: var(--text-h3);
    line-height: 1.08;
    letter-spacing: -0.03em;
  }

  .audience-card p,
  .audience-card li {
    color: var(--ink-soft);
    font-size: 0.97rem;
  }

  .audience-card ul {
    display: grid;
    gap: 0.55rem;
    padding-left: 1rem;
  }

  .audience-card--lead {
    grid-column: span 2;
    background:
      radial-gradient(circle at top right, rgba(72, 101, 255, 0.12), transparent 30%),
      rgba(255, 255, 255, 0.58);
  }

  @media (max-width: 900px) {
    .audience-grid {
      grid-template-columns: 1fr;
    }

    .audience-card--lead {
      grid-column: auto;
    }
  }
</style>
