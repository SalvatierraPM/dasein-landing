---
import TextSplitter from './TextSplitter.astro';
---

<section class="alliance-section" id="alianzas">
  <!-- Olive knot — subtle background depth -->
  <div class="alliance-3d-wrap" data-parallax="0.06" aria-hidden="true">
    <img src="/3d/knot-olive.webp" alt="" class="alliance-3d" loading="lazy" decoding="async" width="200" height="160" />
  </div>

  <div class="container">

    <!-- Asymmetric header -->
    <div class="alliance-head" data-reveal>
      <span class="alliance-kicker">05 / Alianzas</span>
      <h2 class="alliance-title" data-line-reveal><span>Dasein no compite con implementadores.</span><br><span>Les deja un mapa mejor.</span></h2>
    </div>

    <div class="alliance-lede">
      <TextSplitter
        text="Nosotros modelamos. Tú implementas. El cliente decide mejor."
        tag="p"
        animation="blur"
        stagger={10}
      />
    </div>

    <!-- Handoff flow -->
    <div class="alliance-flow" data-reveal-stagger>

      <article class="alliance-col alliance-col--dasein">
        <span class="alliance-step" aria-hidden="true">01</span>
        <div class="alliance-accent alliance-accent--blue"></div>
        <small class="alliance-role">Dasein hace</small>
        <h3 class="alliance-col-title">Lectura, modelamiento y simulación.</h3>
        <p class="alliance-col-body">Pregunta estratégica, señales, actores, escenarios, tensiones y recomendaciones con trazabilidad.</p>
      </article>

      <div class="alliance-connector" aria-hidden="true">
        <div class="alliance-connector-line"></div>
        <svg class="alliance-connector-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M1 6h10M7 2l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <article class="alliance-col alliance-col--partner">
        <span class="alliance-step" aria-hidden="true">02</span>
        <div class="alliance-accent alliance-accent--gradient"></div>
        <small class="alliance-role">Partner implementa</small>
        <h3 class="alliance-col-title">Cambio, despliegue y operación.</h3>
        <p class="alliance-col-body">Transformación, producto, automatización, change management o ejecución institucional según el caso.</p>
      </article>

      <div class="alliance-connector" aria-hidden="true">
        <div class="alliance-connector-line"></div>
        <svg class="alliance-connector-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M1 6h10M7 2l4 4-4 4" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <article class="alliance-col alliance-col--cliente">
        <span class="alliance-step" aria-hidden="true">03</span>
        <div class="alliance-accent alliance-accent--red"></div>
        <small class="alliance-role">Cliente decide</small>
        <h3 class="alliance-col-title">La organización conserva criterio y secuencia.</h3>
        <p class="alliance-col-body">El objetivo es que el equipo tome decisiones con más claridad, no que delegue la lectura del riesgo.</p>
      </article>

    </div>

    <!-- Monumental quote -->
    <blockquote class="alliance-quote" data-quote-reveal>
      <div class="alliance-quote-rule"></div>
      <p class="alliance-quote-body">
        <span class="alliance-quote-line">
          <span class="aq-mono">Donde</span>
          <span class="aq-display">termina</span>
        </span>
        <span class="alliance-quote-line">
          <span class="aq-editorial">nuestro trabajo,</span>
        </span>
        <span class="alliance-quote-line">
          <span class="aq-display">empieza</span>
          <span class="aq-editorial">el tuyo.</span>
        </span>
      </p>
      <div class="alliance-quote-rule"></div>
    </blockquote>

  </div>
</section>

<style>
  /* ── Section ── */
  .alliance-section {
    padding-block: var(--space-section);
    position: relative;
    overflow: visible;
  }

  /* ── Asymmetric Header ── */
  .alliance-head {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(2rem, 3vw, 4rem);
    align-items: start;
    margin-bottom: clamp(2rem, 3vw, 3.5rem);
  }

  .alliance-kicker {
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--ink-faint);
    padding-top: 0.65em;
    white-space: nowrap;
  }

  .alliance-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 1.2rem + 2.4vw, 3.4rem);
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
    max-width: 28ch;
  }

  .alliance-lede {
    color: var(--ink-soft);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    max-width: 52ch;
    margin-left: auto;
    margin-bottom: clamp(4rem, 5vw, 7rem);
  }

  /* ── Flow Grid ── */
  .alliance-flow {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: start;
    gap: 0;
    margin-bottom: clamp(5rem, 6vw, 8rem);
  }

  /* ── Column (NOT a card) ── */
  .alliance-col {
    position: relative;
    padding: clamp(2.5rem, 3vw, 3.5rem) clamp(1.5rem, 2vw, 2.5rem);
    padding-top: clamp(3.5rem, 4vw, 5rem);
  }

  .alliance-col:hover .alliance-accent {
    filter: brightness(1.3);
    opacity: 1;
  }

  /* Step watermark */
  .alliance-step {
    position: absolute;
    top: clamp(0.5rem, 1vw, 1rem);
    right: clamp(1rem, 2vw, 2rem);
    font-family: var(--font-display);
    font-size: clamp(4rem, 3rem + 3vw, 7rem);
    font-weight: 700;
    line-height: 1;
    color: var(--ink);
    opacity: 0.04;
    pointer-events: none;
    user-select: none;
  }

  /* Top accent line */
  .alliance-accent {
    position: absolute;
    top: 0;
    left: clamp(1.5rem, 2vw, 2.5rem);
    right: clamp(1.5rem, 2vw, 2.5rem);
    height: 2px;
    border-radius: 1px;
    transition: filter 0.4s var(--ease-out-expo), opacity 0.4s var(--ease-out-expo);
    opacity: 0.8;
  }

  .alliance-accent--blue {
    background: var(--signal-blue);
  }

  .alliance-accent--gradient {
    background: linear-gradient(90deg, var(--signal-blue), var(--signal-red));
  }

  .alliance-accent--red {
    background: var(--signal-red);
  }

  .alliance-role {
    display: block;
    margin-bottom: clamp(0.75rem, 1vw, 1.25rem);
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: var(--tracking-overline);
    text-transform: uppercase;
    color: var(--signal-red);
  }

  .alliance-col-title {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 1rem + 0.8vw, 2rem);
    line-height: var(--leading-heading);
    letter-spacing: var(--tracking-heading);
    color: var(--ink);
    margin-bottom: clamp(0.75rem, 1vw, 1rem);
  }

  .alliance-col-body {
    color: var(--ink-soft);
    font-size: clamp(0.92rem, 0.88rem + 0.2vw, 1.04rem);
    line-height: var(--leading-body);
  }


  /* ── Connectors ── */
  .alliance-connector {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    padding-top: clamp(4rem, 5vw, 6.5rem);
    width: clamp(2.5rem, 3vw, 4rem);
  }

  .alliance-connector-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--signal-blue), var(--signal-red));
    opacity: 0.28;
    transform-origin: left center;
  }

  .alliance-connector-arrow {
    flex-shrink: 0;
    width: 2.35rem;
    height: 2.35rem;
    padding: 0.6rem;
    border-radius: 999px;
    color: var(--ink);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(255, 248, 239, 0.64)),
      var(--paper-raised);
    border: 1px solid rgba(17, 17, 17, 0.12);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.82),
      0 10px 22px rgba(17, 17, 17, 0.05);
    opacity: 1;
  }

  /* Animate connector line draw-in */
  [data-reveal-stagger] .alliance-connector-line {
    transform: scaleX(0);
    transition: transform 0.7s var(--ease-out-expo);
  }

  [data-reveal-stagger].revealed .alliance-connector-line {
    transform: scaleX(1);
  }

  /* Stagger: connectors animate after columns */
  [data-reveal-stagger].revealed .alliance-connector:nth-of-type(2) .alliance-connector-line {
    transition-delay: 0.35s;
  }

  [data-reveal-stagger].revealed .alliance-connector:nth-of-type(4) .alliance-connector-line {
    transition-delay: 0.5s;
  }

  /* Column stagger overrides */
  [data-reveal-stagger] > .alliance-col {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s var(--ease-out-expo), transform 0.6s var(--ease-out-expo);
  }

  [data-reveal-stagger].revealed > .alliance-col:nth-child(1) {
    transition-delay: 0s;
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-stagger].revealed > .alliance-col:nth-child(3) {
    transition-delay: 0.15s;
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal-stagger].revealed > .alliance-col:nth-child(5) {
    transition-delay: 0.3s;
    opacity: 1;
    transform: translateY(0);
  }

  /* Connectors also hidden initially */
  [data-reveal-stagger] > .alliance-connector {
    opacity: 0;
    transition: opacity 0.5s var(--ease-out-expo);
  }

  [data-reveal-stagger].revealed > .alliance-connector:nth-child(2) {
    transition-delay: 0.25s;
    opacity: 1;
  }

  [data-reveal-stagger].revealed > .alliance-connector:nth-child(4) {
    transition-delay: 0.4s;
    opacity: 1;
  }

  /* ── Quote ── */
  .alliance-quote {
    text-align: center;
    padding: 0;
    margin: 0;
    max-width: 60rem;
    margin-inline: auto;
    padding-block: clamp(2rem, 3vw, 4rem);
  }

  .alliance-quote-body {
    display: grid;
    justify-items: center;
    gap: 0;
    padding-block: clamp(3rem, 5vw, 5.5rem);
  }

  .alliance-quote-line {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0.22em;
    line-height: 1.1;
  }

  /* Mono — small connector words */
  .aq-mono {
    font-family: var(--font-mono);
    font-size: clamp(0.85rem, 0.7rem + 0.5vw, 1.1rem);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
    align-self: center;
    margin-right: 0.15em;
  }

  /* Display — strong action verbs */
  .aq-display {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 1.8rem + 3.5vw, 5.2rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--ink);
    opacity: 0.25;
  }

  /* Editorial — the human parts, warm */
  .aq-editorial {
    font-family: var(--font-editorial);
    font-size: clamp(3.2rem, 2rem + 4vw, 6rem);
    font-style: italic;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--signal-red);
  }

  .alliance-quote-rule {
    height: 1px;
    background: var(--line);
    width: 100%;
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.8s var(--ease-out-expo);
  }

  [data-reveal].revealed .alliance-quote-rule {
    transform: scaleX(1);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal-stagger] > .alliance-col,
    [data-reveal-stagger] > .alliance-connector {
      opacity: 1;
      transform: none;
      transition: none;
    }

    [data-reveal-stagger] .alliance-connector-line {
      transform: scaleX(1);
      transition: none;
    }

    .alliance-quote-rule {
      transform: scaleX(1);
      transition: none;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .alliance-head {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .alliance-lede {
      margin-left: 0;
    }

    .alliance-flow {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .alliance-col {
      padding-left: 0;
      padding-right: 0;
    }

    .alliance-accent {
      left: 0;
      right: 0;
    }

    .alliance-step {
      right: 0;
    }

    /* Vertical connectors on mobile */
    .alliance-connector {
      flex-direction: column;
      width: 100%;
      padding-top: 0;
      padding-block: clamp(1rem, 2vw, 1.5rem);
    }

    .alliance-connector-line {
      width: 1px;
      height: 2.5rem;
      flex: none;
      transform-origin: top center;
      background: linear-gradient(180deg, var(--signal-blue), var(--signal-red));
    }

    .alliance-connector-arrow {
      transform: rotate(90deg);
    }

    /* Re-sequence stagger for vertical layout */
    [data-reveal-stagger] > *:nth-child(1) { transition-delay: 0s !important; }
    [data-reveal-stagger] > *:nth-child(2) { transition-delay: 0.1s !important; }
    [data-reveal-stagger] > *:nth-child(3) { transition-delay: 0.2s !important; }
    [data-reveal-stagger] > *:nth-child(4) { transition-delay: 0.3s !important; }
    [data-reveal-stagger] > *:nth-child(5) { transition-delay: 0.4s !important; }

    .aq-display {
      font-size: clamp(2rem, 1.5rem + 2.5vw, 3.5rem);
    }

    .aq-editorial {
      font-size: clamp(2.2rem, 1.6rem + 2.8vw, 3.8rem);
    }

    .aq-mono {
      font-size: clamp(0.7rem, 0.6rem + 0.4vw, 0.9rem);
    }
  }

  /* ── Mobile editorial refinements ── */
  @media (max-width: 860px) {
    .alliance-quote {
      text-align: center;
      max-width: 100%;
    }

    .alliance-quote-body {
      padding-block: clamp(1.5rem, 3vw, 3rem);
    }

    .aq-display {
      font-size: clamp(1.6rem, 1.2rem + 2vw, 2.4rem);
    }

    .aq-editorial {
      font-size: clamp(1.8rem, 1.4rem + 2.2vw, 2.8rem);
    }

    .alliance-title {
      font-size: clamp(1.6rem, 1.2rem + 1.8vw, 2.6rem);
    }

    .alliance-lede {
      text-align: center;
      margin-inline: auto;
    }

    .alliance-head {
      text-align: center;
    }

    .alliance-head .alliance-kicker {
      text-align: center;
    }

    .alliance-3d-wrap {
      display: none;
    }
  }

  /* ── 3D floating accent ── */
  .alliance-3d-wrap {
    position: absolute;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    will-change: transform;
    width: clamp(120px, 14vw, 200px);
    bottom: 15%;
    left: -2%;
    transform: translateY(var(--plx-y, 0));
  }

  .alliance-3d {
    width: 100%;
    height: auto;
    display: block;
    opacity: 0.38;
    filter: brightness(0.72) saturate(1.3);
    animation: ally-float 15s ease-in-out infinite;
    animation-delay: -5s;
  }

  @keyframes ally-float {
    0%, 100% { transform: rotate(-18deg) translateY(0); }
    50% { transform: rotate(-15deg) translateY(-12px); }
  }

  @media (max-width: 900px) { .alliance-3d-wrap { display: none; } }
  @media (prefers-reduced-motion: reduce) {
    .alliance-3d { animation: none !important; }
    .alliance-3d-wrap { transform: none !important; }
  }

  /* === Quote word-by-word reveal === */
  .js [data-quote-reveal] .aq-mono,
  .js [data-quote-reveal] .aq-display,
  .js [data-quote-reveal] .aq-editorial {
    opacity: 0;
    transform: translateY(24px) scale(0.94);
    filter: blur(4px);
    transition: opacity 0.7s var(--ease-out-expo),
                transform 0.7s var(--ease-out-expo),
                filter 0.5s var(--ease-out-expo);
  }

  .js [data-quote-reveal].is-quote-visible .aq-mono,
  .js [data-quote-reveal].is-quote-visible .aq-display,
  .js [data-quote-reveal].is-quote-visible .aq-editorial {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .js [data-quote-reveal] .aq-mono,
    .js [data-quote-reveal] .aq-display,
    .js [data-quote-reveal] .aq-editorial {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }
</style>

<script>
  /* === Alliance quote: staggered word reveal === */
  (() => {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const quote = document.querySelector('[data-quote-reveal]');
    if (!quote) return;

    const words = quote.querySelectorAll<HTMLElement>('.aq-mono, .aq-display, .aq-editorial');
    const rules = quote.querySelectorAll<HTMLElement>('.alliance-quote-rule');

    const quoteObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        quote.classList.add('is-quote-visible');

        // Stagger each word
        words.forEach((word, i) => {
          word.style.transitionDelay = `${i * 180}ms`;
        });

        // Rules animate after words
        const rulesDelay = words.length * 180 + 200;
        rules.forEach((rule, i) => {
          rule.style.transitionDelay = `${i === 0 ? 0 : rulesDelay}ms`;
        });

        quoteObserver.unobserve(quote);
      });
    }, { threshold: 0.3 });

    quoteObserver.observe(quote);
  })();
</script>
