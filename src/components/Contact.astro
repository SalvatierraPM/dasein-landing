---
import BrandLogo from './BrandLogo.astro';

const calendlyUrl = 'https://calendly.com/salvatierra-pablom/30min';
---

<section class="contact-section section-dark" id="contacto">
  <div class="container">

    <div class="contact-grid" data-reveal>
      <!-- Left: editorial headline -->
      <div class="contact-left">
        <span class="section-kicker contact-kicker">Próximo paso</span>
        <h2 class="contact-headline">
          Hablemos<br />del <em>caso.</em>
        </h2>
      </div>

      <!-- Right: body + action -->
      <div class="contact-right">
        <p class="contact-body">
          Una conversación breve basta para entender si el caso necesita
          un pulso estratégico, una simulación completa o una colaboración
          posterior con partners.
        </p>

        <a class="contact-cta" href={calendlyUrl} target="_blank" rel="noreferrer">
          Agenda una conversación
          <span class="contact-cta-arrow">&rarr;</span>
        </a>

        <div class="contact-channels">
          <a href="mailto:salvatierra.pablom@gmail.com">salvatierra.pablom@gmail.com</a>
          <span class="contact-sep">·</span>
          <a href="https://wa.me/56939056565" target="_blank" rel="noreferrer">+56 9 3905 6565</a>
          <span class="contact-sep">·</span>
          <span>Santiago, Chile</span>
        </div>
      </div>
    </div>

  </div>

  <!-- Minimal footer -->
  <footer class="contact-footer">
    <div class="container contact-footer-inner">
      <a href="#hero" class="contact-footer-brand" aria-label="Dasein Foresight">
        <BrandLogo variant="dark" size="footer" />
      </a>
      <nav class="contact-footer-links" aria-label="External links">
        <a href="https://github.com/SalvatierraPM" target="_blank" rel="noreferrer">GitHub</a>
        <a href="https://substack.com/@pavlogalgo" target="_blank" rel="noreferrer">Substack</a>
      </nav>
      <span class="contact-footer-copy">&copy; 2025</span>
    </div>
  </footer>
</section>

<style>
  .contact-section {
    padding-top: clamp(10rem, 8rem + 10vw, 20rem);
    padding-bottom: 0;
  }

  /* ─── Asymmetric editorial grid ─── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(4rem, 6vw, 8rem);
    align-items: start;
  }

  .contact-left {
    display: grid;
    gap: 1.8rem;
  }

  .contact-kicker {
    color: rgba(243, 245, 248, 0.36);
  }

  .contact-headline {
    font-family: var(--font-display);
    font-size: clamp(5rem, 2.5rem + 9vw, 11rem);
    font-weight: 600;
    line-height: 0.85;
    letter-spacing: -0.05em;
    color: var(--slate-white);
  }

  .contact-headline em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
    color: var(--signal-red);
  }

  .contact-right {
    display: grid;
    gap: clamp(2.5rem, 3.5vw, 4rem);
    padding-top: clamp(1.5rem, 3vw, 5rem);
  }

  .contact-body {
    color: rgba(243, 245, 248, 0.52);
    font-size: clamp(1.05rem, 1rem + 0.3vw, 1.2rem);
    line-height: 1.72;
    max-width: 34ch;
  }

  /* ─── CTA: editorial underline style ─── */
  .contact-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 1.1rem + 1vw, 2.2rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--slate-white);
    text-decoration: none;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(243, 245, 248, 0.2);
    width: fit-content;
    transition: border-color 0.4s ease;
  }

  .contact-cta:hover {
    border-color: var(--signal-red);
  }

  .contact-cta-arrow {
    transition: transform 0.4s var(--ease-out-expo);
  }

  .contact-cta:hover .contact-cta-arrow {
    transform: translateX(4px);
  }

  .contact-cta:focus-visible {
    outline: 2px solid var(--signal-red);
    outline-offset: 6px;
  }

  /* ─── Channels: inline, subdued ─── */
  .contact-channels {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: rgba(243, 245, 248, 0.36);
  }

  .contact-channels a {
    color: rgba(243, 245, 248, 0.48);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-channels a:hover {
    color: var(--slate-white);
  }

  .contact-sep {
    opacity: 0.3;
  }

  /* ─── Footer ─── */
  .contact-footer {
    margin-top: clamp(6rem, 5rem + 5vw, 12rem);
    border-top: 1px solid rgba(243, 245, 248, 0.06);
    padding: clamp(1.5rem, 2vw, 2.5rem) 0;
  }

  .contact-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .contact-footer-brand {
    display: inline-flex;
    align-items: center;
  }

  .contact-footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .contact-footer-links a {
    font-size: 0.75rem;
    color: rgba(243, 245, 248, 0.36);
    text-decoration: none;
    transition: color var(--dur-fast) ease;
  }

  .contact-footer-links a:hover {
    color: var(--slate-white);
  }

  .contact-footer-copy {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: rgba(243, 245, 248, 0.2);
  }

  /* ─── Mobile ─── */
  @media (max-width: 860px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: clamp(2rem, 4vw, 3rem);
    }

    .contact-headline {
      font-size: clamp(3.2rem, 2rem + 6vw, 5.5rem);
    }

    .contact-right {
      padding-top: 0;
    }

    .contact-channels {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.4rem;
    }

    .contact-sep {
      display: none;
    }

    .contact-footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.8rem;
    }
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .contact-cta,
    .contact-channels a {
      transition: none;
    }
  }
</style>
