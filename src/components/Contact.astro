---
import BrandLogo from './BrandLogo.astro';
import Aurora from './Aurora.astro';

const bookingUrl = 'https://daseinforesight.zohobookings.com/#/4731633000000049054';
---

<section class="contact-section section-dark" id="contacto">
  <Aurora
    class="contact-aurora"
    colorA="rgba(72, 101, 255, 0.12)"
    colorB="rgba(255, 92, 56, 0.06)"
    colorC="rgba(122, 104, 214, 0.08)"
    speed={0.6}
  />
  <div class="container">
    <div class="contact-spread" data-reveal>
      <div class="contact-head">
        <span class="section-kicker contact-kicker">Próximo paso</span>
        <h2 class="contact-headline" data-line-reveal>
          <span>Hablemos</span>
          <span class="contact-headline-row">
            <span class="contact-headline-prep">del</span> <em>caso.</em>
          </span>
        </h2>
      </div>

      <div class="contact-aside">
        <p class="contact-body">
          <span class="contact-data">30 minutos</span> para entender tu caso y ver si podemos <em>ayudar.</em>
        </p>

        <div class="contact-cta-block">
          <span class="contact-cta-index" aria-hidden="true">01</span>
          <a class="contact-cta" href={bookingUrl} target="_blank" rel="noreferrer">
            <span class="contact-cta-copy">
              <span class="contact-cta-label">Sesión inicial</span>
              <span class="contact-cta-title">Agenda una conversación</span>
              <span class="contact-cta-meta">30 min ◇ remota ◇ Zoho Bookings</span>
            </span>
            <span class="contact-cta-arrow">&rarr;</span>
          </a>
        </div>

        <div class="contact-ledger" data-reveal-stagger aria-label="Información de contacto">
          <div class="contact-ledger-item">
            <span class="contact-ledger-label">Email</span>
            <a href="mailto:pablo@daseinfs.com">pablo@daseinfs.com</a>
          </div>
          <div class="contact-ledger-item">
            <span class="contact-ledger-label">Teléfono</span>
            <a href="https://wa.me/56939056565" target="_blank" rel="noreferrer">+56 9 3905 6565</a>
          </div>
          <div class="contact-ledger-item">
            <span class="contact-ledger-label">Base</span>
            <span>Santiago, Chile</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Minimal footer -->
  <footer class="contact-footer">
    <div class="container contact-footer-inner">
      <a href="#hero" class="contact-footer-brand" aria-label="Dasein Foresight">
        <BrandLogo variant="dark" size="footer" />
      </a>
      <nav class="contact-footer-links" aria-label="External links">
        <a href="https://github.com/SalvatierraPM" target="_blank" rel="noreferrer">GitHub</a>
        <a href="https://substack.com/@pavlogalgo" target="_blank" rel="noreferrer">Substack</a>
      </nav>
      <span class="contact-footer-copy">&copy; 2026</span>
    </div>
  </footer>
</section>

<style>
  .contact-section {
    padding-top: clamp(10rem, 8rem + 10vw, 20rem);
    padding-bottom: 0;
    position: relative;
    overflow: hidden;
  }

  .contact-aurora {
    opacity: 0.6;
    mask-image: radial-gradient(ellipse 70% 60% at 30% 40%, black 0%, transparent 100%);
  }

  .contact-spread {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(20rem, 0.8fr);
    gap: clamp(4rem, 6vw, 8rem);
    align-items: start;
  }

  .contact-head {
    display: grid;
    gap: clamp(1.5rem, 2vw, 2.3rem);
  }

  .contact-kicker {
    color: rgba(243, 245, 248, 0.36);
  }

  .contact-headline {
    font-family: var(--font-display);
    font-size: clamp(3.9rem, 2rem + 6vw, 7rem);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.04em;
    color: var(--slate-white);
    display: grid;
    max-width: 14ch;
  }

  .contact-headline-row {
    display: flex;
    align-items: baseline;
    gap: 0.04em;
  }

  .contact-headline em {
    font-family: var(--font-editorial);
    font-style: italic;
    font-weight: 400;
    color: var(--signal-red);
  }

  .contact-headline-prep {
    font-family: var(--font-mono);
    font-size: 0.45em;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: rgba(243, 245, 248, 0.4);
    align-self: center;
  }

  .contact-aside {
    display: grid;
    gap: clamp(2rem, 2.6vw, 3.2rem);
    padding-top: clamp(1rem, 2vw, 3rem);
  }

  .contact-body {
    color: rgba(243, 245, 248, 0.58);
    font-size: clamp(1rem, 0.96rem + 0.24vw, 1.12rem);
    line-height: 1.82;
    max-width: 30ch;
  }

  .contact-data {
    font-family: var(--font-mono);
    font-weight: 600;
    color: rgba(243, 245, 248, 0.82);
    letter-spacing: -0.01em;
  }

  .contact-body em {
    font-family: var(--font-editorial);
    font-style: italic;
    color: rgba(243, 245, 248, 0.72);
  }

  .contact-cta-block {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1rem, 1.6vw, 1.6rem);
    align-items: start;
    padding-top: clamp(1.25rem, 1vw, 1.6rem);
    border-top: 1px solid rgba(243, 245, 248, 0.16);
  }

  .contact-cta-index {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(243, 245, 248, 0.3);
    padding-top: 0.55rem;
  }

  .contact-cta {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid rgba(243, 245, 248, 0.14);
    color: var(--slate-white);
    text-decoration: none;
  }

  .contact-cta-copy {
    display: grid;
    gap: 0.65rem;
  }

  .contact-cta-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(243, 245, 248, 0.38);
  }

  .contact-cta-label::before {
    content: '◈';
    color: var(--signal-red);
    opacity: 0.4;
    margin-right: 0.3rem;
  }

  .contact-cta-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 1.2rem + 1.2vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: var(--tracking-heading);
    color: var(--slate-white);
  }

  .contact-cta-meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(243, 245, 248, 0.36);
  }

  .contact-cta-arrow {
    align-self: center;
    font-size: clamp(1.8rem, 1.2rem + 0.8vw, 2.3rem);
    color: rgba(243, 245, 248, 0.78);
    transition: transform 0.4s var(--ease-out-expo), color 0.4s ease;
  }

  .contact-cta:hover .contact-cta-arrow {
    transform: translateX(5px);
    color: var(--signal-red);
  }

  .contact-cta:focus-visible {
    outline: 2px solid var(--signal-red);
    outline-offset: 6px;
  }

  .contact-ledger {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding-top: 0.2rem;
  }

  .contact-ledger-item {
    display: grid;
    grid-template-columns: minmax(4.75rem, auto) 1fr;
    align-items: start;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(243, 245, 248, 0.08);
  }

  .contact-ledger-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(243, 245, 248, 0.36);
  }

  .contact-ledger-item a,
  .contact-ledger-item span:last-child {
    font-size: clamp(0.9rem, 0.86rem + 0.12vw, 0.98rem);
    line-height: 1.55;
    color: rgba(243, 245, 248, 0.48);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-ledger-item a:hover {
    color: var(--slate-white);
  }

  /* ─── Footer ─── */
  .contact-footer {
    margin-top: clamp(6rem, 5rem + 5vw, 12rem);
    border-top: 1px solid rgba(243, 245, 248, 0.06);
    padding: clamp(1.5rem, 2vw, 2.5rem) 0;
  }

  .contact-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .contact-footer-brand {
    display: inline-flex;
    align-items: center;
  }

  .contact-footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .contact-footer-links a {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: rgba(243, 245, 248, 0.36);
    text-decoration: none;
    transition: color var(--dur-fast) ease;
  }

  .contact-footer-links a:hover {
    color: var(--slate-white);
  }

  .contact-footer-copy {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: rgba(243, 245, 248, 0.2);
  }

  /* ─── Mobile ─── */
  @media (max-width: 860px) {
    .contact-section {
      padding-top: clamp(6rem, 5rem + 6vw, 12rem);
    }

    .contact-spread {
      grid-template-columns: 1fr;
      gap: clamp(2rem, 4vw, 3rem);
    }

    .contact-headline {
      font-size: clamp(2.9rem, 1.95rem + 5vw, 4.9rem);
      max-width: none;
    }

    .contact-aside {
      padding-top: 0;
    }

    .contact-body {
      max-width: 100%;
    }

    .contact-cta-block {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .contact-cta-index {
      padding-top: 0;
    }

    .contact-cta {
      width: 100%;
    }

    .contact-ledger {
      grid-template-columns: 1fr;
      gap: 0.8rem;
    }

    .contact-ledger-item {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }

    .contact-footer-inner {
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
    }

    .contact-footer-links {
      justify-content: center;
    }
  }

  /* ─── Ledger item stagger entrance ─── */
  [data-reveal-stagger] .contact-ledger-item {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s var(--ease-out-expo), transform 0.5s var(--ease-out-expo);
  }

  [data-reveal-stagger].revealed .contact-ledger-item:nth-child(1) { opacity: 1; transform: translateY(0); transition-delay: 0s; }
  [data-reveal-stagger].revealed .contact-ledger-item:nth-child(2) { opacity: 1; transform: translateY(0); transition-delay: 0.08s; }
  [data-reveal-stagger].revealed .contact-ledger-item:nth-child(3) { opacity: 1; transform: translateY(0); transition-delay: 0.16s; }

  /* ─── CTA hover text-shadow ─── */
  .contact-cta:hover .contact-cta-title {
    text-shadow: 0 0 24px rgba(255, 92, 56, 0.3);
  }

  .contact-cta-title {
    transition: text-shadow 0.4s var(--ease-out-expo);
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .contact-cta-arrow,
    .contact-ledger-item a {
      transition: none;
    }

    [data-reveal-stagger] .contact-ledger-item {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .contact-cta-title {
      transition: none;
    }
  }
</style>
