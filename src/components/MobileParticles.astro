---
/**
 * MobileParticles — lightweight 2D canvas particle system
 * Only renders on viewports < 860px. Desktop does nothing.
 * ~30 subtle dots that drift upward with horizontal sway.
 * Scroll-reactive: particles drift faster as you scroll.
 * Respects prefers-reduced-motion.
 */
---

<canvas
  class="mobile-particles"
  id="mobile-particles-canvas"
  aria-hidden="true"
></canvas>

<style>
  .mobile-particles {
    display: none;
  }

  @media (max-width: 860px) {
    .mobile-particles {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      width: 100%;
      height: 100%;
    }
  }
</style>

<script>
  (() => {
    // Bail on desktop or reduced motion
    if (window.matchMedia('(min-width: 861px)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const canvas = document.getElementById('mobile-particles-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const PARTICLE_COUNT = 30;
    const BLUE = { r: 72, g: 101, b: 255 };  // --signal-blue
    const RED = { r: 255, g: 92, b: 56 };     // --signal-red

    let dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0;
    let h = 0;
    let scrollVelocity = 0;
    let lastScrollY = window.scrollY;
    let rafId = 0;

    interface Particle {
      x: number;
      y: number;
      radius: number;
      baseSpeed: number;
      swayAmplitude: number;
      swayFrequency: number;
      phase: number;
      color: typeof BLUE;
      opacity: number;
    }

    const particles: Particle[] = [];

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = window.innerWidth;
      h = window.innerHeight;
      canvas!.width = w * dpr;
      canvas!.height = h * dpr;
      canvas!.style.width = `${w}px`;
      canvas!.style.height = `${h}px`;
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function createParticle(): Particle {
      const isBlue = Math.random() > 0.4;
      return {
        x: Math.random() * w,
        y: Math.random() * h,
        radius: 1.2 + Math.random() * 1.8,
        baseSpeed: 0.15 + Math.random() * 0.35,
        swayAmplitude: 12 + Math.random() * 20,
        swayFrequency: 0.0008 + Math.random() * 0.0012,
        phase: Math.random() * Math.PI * 2,
        color: isBlue ? BLUE : RED,
        opacity: isBlue ? 0.15 : 0.10,
      };
    }

    function init() {
      resize();
      particles.length = 0;
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push(createParticle());
      }
    }

    function draw(time: number) {
      if (!ctx) return;
      ctx.clearRect(0, 0, w, h);

      // Scroll velocity factor: 1 at rest, up to ~3 when scrolling fast
      const scrollBoost = 1 + Math.min(Math.abs(scrollVelocity) * 0.08, 2);

      for (const p of particles) {
        // Upward drift + scroll boost
        p.y -= p.baseSpeed * scrollBoost;

        // Horizontal sway
        const sway = Math.sin(time * p.swayFrequency + p.phase) * p.swayAmplitude * 0.02;
        p.x += sway;

        // Wrap around
        if (p.y < -10) {
          p.y = h + 10;
          p.x = Math.random() * w;
        }
        if (p.x < -10) p.x = w + 10;
        if (p.x > w + 10) p.x = -10;

        // Draw
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${p.color.r}, ${p.color.g}, ${p.color.b}, ${p.opacity})`;
        ctx.fill();
      }

      // Decay scroll velocity
      scrollVelocity *= 0.92;

      rafId = requestAnimationFrame(draw);
    }

    // Track scroll velocity
    let scrollTicking = false;
    window.addEventListener('scroll', () => {
      const currentY = window.scrollY;
      scrollVelocity = currentY - lastScrollY;
      lastScrollY = currentY;

      if (!scrollTicking) {
        scrollTicking = true;
        requestAnimationFrame(() => { scrollTicking = false; });
      }
    }, { passive: true });

    window.addEventListener('resize', () => {
      resize();
    }, { passive: true });

    init();
    rafId = requestAnimationFrame(draw);

    // Cleanup on view transitions
    document.addEventListener('astro:before-preparation', () => {
      cancelAnimationFrame(rafId);
    }, { once: true });
  })();
</script>
