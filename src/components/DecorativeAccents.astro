---
/**
 * DecorativeAccents — Floating gradient orbs, abstract SVG lines,
 * and glass spheres that add atmospheric depth behind page content.
 * Pure CSS animations, no JS. Hidden on mobile for GPU savings.
 */
---

<div class="deco-accents" aria-hidden="true">
  <!-- Gradient orbs -->
  <div class="deco-orb deco-orb--peach"></div>
  <div class="deco-orb deco-orb--blue"></div>
  <div class="deco-orb deco-orb--violet"></div>
  <div class="deco-orb deco-orb--teal"></div>
  <div class="deco-orb deco-orb--warm"></div>

  <!-- Abstract SVG line accents -->
  <svg class="deco-line deco-line--sine" viewBox="0 0 400 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0 30 C50 10, 100 50, 150 30 S250 10, 300 30 S400 50, 400 30" stroke="var(--ink)" stroke-width="0.75" stroke-linecap="round"/>
  </svg>

  <svg class="deco-line deco-line--cross-1" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
    <line x1="10" y1="2" x2="10" y2="18" stroke="var(--ink)" stroke-width="0.75" stroke-linecap="round"/>
    <line x1="2" y1="10" x2="18" y2="10" stroke="var(--ink)" stroke-width="0.75" stroke-linecap="round"/>
  </svg>

  <svg class="deco-line deco-line--cross-2" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
    <line x1="10" y1="3" x2="10" y2="17" stroke="var(--ink)" stroke-width="0.75" stroke-linecap="round"/>
    <line x1="3" y1="10" x2="17" y2="10" stroke="var(--ink)" stroke-width="0.75" stroke-linecap="round"/>
  </svg>

  <!-- Glass spheres -->
  <div class="deco-glass deco-glass--1"></div>
  <div class="deco-glass deco-glass--2"></div>
  <div class="deco-glass deco-glass--3"></div>
</div>

<style>
  /* ── Wrapper ── */
  .deco-accents {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    contain: layout style;
    overflow: hidden;
  }

  /* ── Keyframes ── */
  @keyframes float-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }

  @keyframes float-medium {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-9px) rotate(1.5deg); }
  }

  @keyframes float-fast {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-7px) scale(1.02); }
  }

  @keyframes float-drift {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(3px, -10px); }
    66% { transform: translate(-2px, -5px); }
  }

  /* ── Gradient orbs ── */
  .deco-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    will-change: transform;
  }

  .deco-orb--peach {
    width: 11rem;
    height: 11rem;
    top: 8%;
    right: 12%;
    background: radial-gradient(circle, rgba(255, 184, 115, 0.3), transparent 70%);
    opacity: 0.12;
    animation: float-slow 10s ease-in-out infinite;
  }

  .deco-orb--blue {
    width: 14rem;
    height: 14rem;
    top: 38%;
    left: 4%;
    background: radial-gradient(circle, rgba(72, 101, 255, 0.25), transparent 70%);
    opacity: 0.08;
    animation: float-medium 12s ease-in-out infinite;
    animation-delay: -3s;
  }

  .deco-orb--violet {
    width: 8rem;
    height: 8rem;
    top: 55%;
    right: 18%;
    background: radial-gradient(circle, rgba(122, 104, 214, 0.2), transparent 70%);
    opacity: 0.1;
    animation: float-drift 14s ease-in-out infinite;
    animation-delay: -5s;
  }

  .deco-orb--teal {
    width: 6rem;
    height: 6rem;
    bottom: 14%;
    left: 22%;
    background: radial-gradient(circle, rgba(47, 158, 144, 0.15), transparent 70%);
    opacity: 0.1;
    animation: float-fast 8s ease-in-out infinite;
    animation-delay: -2s;
  }

  .deco-orb--warm {
    width: 9rem;
    height: 9rem;
    bottom: 28%;
    right: 6%;
    background: radial-gradient(circle, rgba(200, 159, 51, 0.12), transparent 70%);
    opacity: 0.07;
    animation: float-slow 11s ease-in-out infinite;
    animation-delay: -7s;
  }

  /* ── SVG line accents ── */
  .deco-line {
    position: absolute;
    pointer-events: none;
  }

  .deco-line--sine {
    width: clamp(180px, 22vw, 320px);
    height: auto;
    top: 22%;
    left: 8%;
    opacity: 0.055;
    animation: float-medium 16s ease-in-out infinite;
    animation-delay: -4s;
  }

  .deco-line--cross-1 {
    width: 14px;
    height: 14px;
    top: 32%;
    right: 28%;
    opacity: 0.07;
    animation: float-fast 9s ease-in-out infinite;
    animation-delay: -1s;
  }

  .deco-line--cross-2 {
    width: 11px;
    height: 11px;
    top: 68%;
    left: 14%;
    opacity: 0.06;
    animation: float-slow 13s ease-in-out infinite;
    animation-delay: -6s;
  }

  /* ── Glass spheres ── */
  .deco-glass {
    position: absolute;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    will-change: transform;
  }

  .deco-glass--1 {
    width: 1.6rem;
    height: 1.6rem;
    top: 16%;
    left: -0.4rem;
    opacity: 0.5;
    animation: float-drift 11s ease-in-out infinite;
    animation-delay: -2s;
  }

  .deco-glass--2 {
    width: 1.1rem;
    height: 1.1rem;
    top: 48%;
    right: -0.3rem;
    opacity: 0.4;
    animation: float-medium 9s ease-in-out infinite;
    animation-delay: -5s;
  }

  .deco-glass--3 {
    width: 1.8rem;
    height: 1.8rem;
    bottom: 22%;
    right: 3%;
    opacity: 0.35;
    animation: float-slow 13s ease-in-out infinite;
    animation-delay: -8s;
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .deco-orb,
    .deco-line,
    .deco-glass {
      animation: none !important;
    }
  }

  /* ── Hide on mobile ── */
  @media (max-width: 767px) {
    .deco-accents {
      display: none;
    }
  }
</style>
